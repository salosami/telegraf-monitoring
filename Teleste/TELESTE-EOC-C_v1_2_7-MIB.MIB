    ::= { plQoSPerUserEntry 5 }

    plQoSPerUserPriorityAllowedDown   OBJECT-TYPE
    SYNTAX           OCTET STRING ( SIZE ( 2 ) )
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Allowed priorities for transmission and reception in downstream for a user"
    ::= { plQoSPerUserEntry 6 }



