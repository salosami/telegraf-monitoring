-- plStatistics Table

plStatisticsTable   OBJECT-TYPE
    SYNTAX      SEQUENCE OF PlStatisticsEntry
    ACCESS      not-accessible
    STATUS      current
    DESCRIPTION "Packets and Bytes Statistics by Interface"
    ::= { plWiscStatistics 1 }

    plStatisticsEntry   OBJECT-TYPE
        SYNTAX      PlStatisticsEntry
        ACCESS      not-accessible
        STATUS      current
        DESCRIPTION ""
        INDEX       { plStatisticsCard }
        ::= { plStatisticsTable 1 }
    
    PlStatisticsEntry ::= SEQUENCE {   plStatisticsCard                         INTEGER,
                                       plStatisticsPreprocessorDroppedPkts      Counter,
                                       plStatisticsPortFinderDroppedPkts        Counter,
                                       plStatisticsReplicantDroppedPkts         Counter,
                                       plStatisticsExtAInputBytes               Counter,
                                       plStatisticsExtAInputPkts                Counter,
                                       plStatisticsExtAInputBadCRC              Counter,
                                       plStatisticsExtAInputDiscardedPkts       Counter,
                                       plStatisticsExtAOutputBytes              Counter,
                                       plStatisticsExtAOutputPkts               Counter,
                                       plStatisticsExtAOutputCollisions         Counter,
                                       plStatisticsExtBInputBytes               Counter,
                                       plStatisticsExtBInputPkts                Counter,
                                       plStatisticsExtBInputBadCRC              Counter,
                                       plStatisticsExtBInputDiscardedPkts       Counter,
                                       plStatisticsExtBOutputBytes              Counter,
                                       plStatisticsExtBOutputPkts               Counter,
                                       plStatisticsExtBOutputCollisions         Counter,
				       plStatisticsPLCInputWords                Counter,
				       plStatisticsPLCInputPackets              Counter,
				       plStatisticsPLCInputIncorrigible         Counter,
				       plStatisticsPLCInputFECBlocksTotal       Counter,
				       plStatisticsPLCInputFECBlocksCorrected   Counter,
				       plStatisticsPLCInputPktsReceived         Counter,
				       plStatisticsPLCInputPktsRcvComplete      Counter,
				       plStatisticsPLCInputPktsRcvIncomplete    Counter,
				       plStatisticsPLCOutputWords               Counter,
				       plStatisticsPLCOutputPkts                Counter
			            }

    plStatisticsCard  OBJECT-TYPE
    SYNTAX           INTEGER
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Node card number"
    ::= { plStatisticsEntry 1 }

    plStatisticsPreprocessorDroppedPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets dropped by the Preprocessor"
    ::= { plStatisticsEntry 2 }

    plStatisticsPortFinderDroppedPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets dropped by the PortFinder"
    ::= { plStatisticsEntry 3 }

    plStatisticsReplicantDroppedPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets dropped by the Replicant"
    ::= { plStatisticsEntry 4 }
    
    plStatisticsExtAInputBytes  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Bytes received by EXTA"
    ::= { plStatisticsEntry 5 }

    plStatisticsExtAInputPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received by EXTA"
    ::= { plStatisticsEntry 6 }

    plStatisticsExtAInputBadCRC  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received with bad CRC by EXTA"
    ::= { plStatisticsEntry 7 }

    plStatisticsExtAInputDiscardedPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received but discarded by EXTA"
    ::= { plStatisticsEntry 8 }

    plStatisticsExtAOutputBytes  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Bytes transmitted by EXTA"
    ::= { plStatisticsEntry 9 }

    plStatisticsExtAOutputPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets transmitted by EXTA"
    ::= { plStatisticsEntry 10 }

    plStatisticsExtAOutputCollisions  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Collisions in transmission by EXTA"
    ::= { plStatisticsEntry 11 }

    plStatisticsExtBInputBytes  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Bytes received by EXTB"
    ::= { plStatisticsEntry 12 }

    plStatisticsExtBInputPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received by EXTB"
    ::= { plStatisticsEntry 13 }

    plStatisticsExtBInputBadCRC  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received with bad CRC by EXTB"
    ::= { plStatisticsEntry 14 }

    plStatisticsExtBInputDiscardedPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets received but discarded by EXTB"
    ::= { plStatisticsEntry 15 }

    plStatisticsExtBOutputBytes  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Bytes transmitted by EXTB"
    ::= { plStatisticsEntry 16 }

    plStatisticsExtBOutputPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Packets transmitted by EXTB"
    ::= { plStatisticsEntry 17 }

    plStatisticsExtBOutputCollisions  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Collisions in transmission by EXTB"
    ::= { plStatisticsEntry 18 }

    plStatisticsPLCInputWords  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Words received by PLC"
    ::= { plStatisticsEntry 19 }

    plStatisticsPLCInputPackets   OBJECT-TYPE
    SYNTAX   Counter
    ACCESS   read-only
    STATUS   current
    DESCRIPTION   "Packets received by PLC"
    ::= { plStatisticsEntry 20}


    plStatisticsPLCInputIncorrigible  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Incorrigible packets received by PLC"
    ::= { plStatisticsEntry 21 }

    plStatisticsPLCInputFECBlocksTotal    OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Received FEC blocks by PLC"
    ::= { plStatisticsEntry 22 }
    
    plStatisticsPLCInputFECBlocksCorrected	OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "FEC blocks corrected by PLC"
    ::= { plStatisticsEntry 23 }
    
    plStatisticsPLCInputPktsReceived		OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Received packets by PLC"
    ::= { plStatisticsEntry 24 }
    
    plStatisticsPLCInputPktsRcvComplete   OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Complete received packets by PLC"
    ::= { plStatisticsEntry 25 }
    
    plStatisticsPLCInputPktsRcvIncomplete  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Incomplete received packets by PLC"
    ::= { plStatisticsEntry 26 }
    
    plStatisticsPLCOutputWords  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Transmitted words by PLC"
    ::= { plStatisticsEntry 27 }

    plStatisticsPLCOutputPkts  OBJECT-TYPE
    SYNTAX           Counter
    ACCESS           read-only
    STATUS           current
    DESCRIPTION      "Transmitted packets by PLC"
    ::= { plStatisticsEntry 28 }

-- End of plStatistics Table



