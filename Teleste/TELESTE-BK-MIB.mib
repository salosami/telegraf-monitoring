		-- 1.3.6.1.4.1.3715.3.3.6.1.23
		oTrActivity OBJECT-TYPE
			SYNTAX INTEGER
				{
				rxSleeping(1),
				rxActive(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Module activity:
				1 = sleeping
				2 = active"
			::= { oTrEntry 23 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.24
		oTrMainReserveMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeReserve(1),
				modeMain(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Role of the transceiver in 1+1 backup configuration:
				1 =  reserve unit (Default inactive)
				2 =  main unit (Default active)"
			::= { oTrEntry 24 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.25
		oTrCodeUsage OBJECT-TYPE
			SYNTAX INTEGER
				{
				lineCodeInactive(1),
				lineCodeActive(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Usage of the line codes:
				1 = line codes are not used
				2 = line codes are used
				Line codes are used to control backup switching in 1+1
				backup configuration."
			::= { oTrEntry 25 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.26
		oTrTxPilotStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				pilotNormal(1),
				pilotFailure(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Transmitter pilot generator status:
				1 = normal
				2 = pilot failure"
			::= { oTrEntry 26 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.27
		oTrLaserStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				laserNormal(1),
				laserFailure(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser status:
				1 = normal
				2 = failure"
			::= { oTrEntry 27 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.28
		oTrLinkStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				linkNormal(1),
				linkReserveUnitActive(2),
				linkMainUnitSleeping(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Link status:
				1 = normal
				2 = reserve unit is active
				3 = main unit is sleeping
				
				With BOX860 the meaning of value 2 depends on the unit
				configuration.
				
				Main unit: 2 = unit sleeping
				Reserve unit: 2 = unit active"
			::= { oTrEntry 28 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.29
		oTrRxInputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical input power status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oTrEntry 29 }

		
