			DESCRIPTION
				"bVrTable contains element specific information for
				B amplifier (BKA603/803) modules in a BK system."
			::= { bkModules1 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1
		bVrEntry OBJECT-TYPE
			SYNTAX BVrEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { bVrTable 1 }

		
		BVrEntry ::=
			SEQUENCE { 
				bVrGain
					Int16,
				bVrDetOffset
					Int16,
				bVrDetRefValue
					Int16,
				bVrDetOffsetHiHi
					Uint16,
				bVrDetOffsetHi
					Uint16,
				bVrDetOffsetLo
					Int16,
				bVrDetOffsetLoLo
					Int16,
				bVrDetOffsetDeadband
					Uint16,
				bVrDetRefMode
					INTEGER,
				bVrDetAverageMode
					INTEGER,
				bVrRfLevelStatus
					INTEGER,
				bVrTemperatureStatus
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.3.2.1.1
		bVrGain OBJECT-TYPE
			SYNTAX Int16 (-400..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value. Unit 0.01 dB.
				This object is implemented only with BKA803."
			::= { bVrEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.2
		bVrDetOffset OBJECT-TYPE
			SYNTAX Int16 (-10000..10000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset value, in reference to aAmpDetRefValue.
				Unit 0.01 dB."
			::= { bVrEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.3
		bVrDetRefValue OBJECT-TYPE
			SYNTAX Int16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband level detector reference. This is used
				as a reference point for limit values. Unit 0.01 dB."
			::= { bVrEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.4
		bVrDetOffsetHiHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset high alarm limit. Unit 0.01 dB."
			::= { bVrEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.5
		bVrDetOffsetHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset high warning limit. Unit 0.01 dB."
			::= { bVrEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.6
		bVrDetOffsetLo OBJECT-TYPE
			SYNTAX Int16 (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset low warning limit. Unit 0.01 dB."
			::= { bVrEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.7
		bVrDetOffsetLoLo OBJECT-TYPE
			SYNTAX Int16 (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset low alarm limit. Unit 0.01 dB."
			::= { bVrEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.8
		bVrDetOffsetDeadband OBJECT-TYPE
			SYNTAX Uint16 (50..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset deadband. Unit 0.01 dB."
			::= { bVrEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.9
		bVrDetRefMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				refFactory(1),
				refCustom(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Used broadband detector reference value:
				1 = factory set reference
				2 = custom reference"
			::= { bVrEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.10
		bVrDetAverageMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				averagingOff(1),
				averagingOn(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector's averaging status:
				1 = averaging off
				2 = averaging on"
			::= { bVrEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.11
		bVrRfLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF level status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { bVrEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.2.1.12
		bVrTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { bVrEntry 12 }

		
-- cVrTable contains element specific information for
-- C amplifier (BKC629/829) modules in a BK
-- system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.3
		cVrTable OBJECT-TYPE
			SYNTAX SEQUENCE OF CVrEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"cVrTable contains element specific information for
				C amplifier (BKC629/829) modules in a BK system."
			::= { bkModules1 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1
		cVrEntry OBJECT-TYPE
			SYNTAX CVrEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { cVrTable 1 }

		
		CVrEntry ::=
			SEQUENCE { 
				cVrGain
					Int16,
				cVrSlope
					Int16,
				cVrDetOffset
					Int16,
				cVrDetRefValue
					Int16,
				cVrDetOffsetHiHi
					Uint16,
				cVrDetOffsetHi
					Uint16,
				cVrDetOffsetLo
					Int16,
				cVrDetOffsetLoLo
					Int16,
				cVrDetOffsetDeadband
					Uint16,
				cVrDetRefMode
					INTEGER,
				cVrDetAverageMode
					INTEGER,
				cVrRfLevelStatus
					INTEGER,
				cVrTemperatureStatus
					INTEGER,
				cVrForwardFrequencyMode
					INTEGER,
				cVrReturnFrequencyMode
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.3.3.1.1
		cVrGain OBJECT-TYPE
			SYNTAX Int16 (-400..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value. Unit 0.01 dB.
				"
			::= { cVrEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.2
		cVrSlope OBJECT-TYPE
			SYNTAX Int16
				{
				slope0dB(1),
				slope3dB(2),
				slope6dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High-end slope control.
				
				For BKC629 the value is enumerated:
				
				1 = 0 dB
				2 = -3 dB
				3 = -6 dB
				
				With older BKC829 modules, high-end slope control is continuous from
				0 to -6 dB. With 0.01 dB resolution the value range is thus 0 to -600.
				"
			::= { cVrEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.3
		cVrDetOffset OBJECT-TYPE
			SYNTAX Int16 (-10000..10000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset value, in reference to cAmpDetRefValue.
				Unit 0.01 dB."
			::= { cVrEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.4
		cVrDetRefValue OBJECT-TYPE
			SYNTAX Int16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband level detector reference. This is used as a reference
				point for limit values. Unit 0.01 dB."
			::= { cVrEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.5
		cVrDetOffsetHiHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset high alarm limit. Unit 0.01 dB."
			::= { cVrEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.6
		cVrDetOffsetHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset high warning limit. Unit 0.01 dB."
			::= { cVrEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.7
		cVrDetOffsetLo OBJECT-TYPE
			SYNTAX Int16 (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset low warning limit. Unit 0.01 dB."
			::= { cVrEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.8
		cVrDetOffsetLoLo OBJECT-TYPE
			SYNTAX Int16 (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset low alarm limit. Unit 0.01 dB."
			::= { cVrEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.9
		cVrDetOffsetDeadband OBJECT-TYPE
			SYNTAX Uint16 (50..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector offset deadband. Unit 0.01 dB."
			::= { cVrEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.10
		cVrDetRefMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				refFactory(1),
				refCustom(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Used broadband detector reference value:
				1 = factory set reference
				2 = custom reference"
			::= { cVrEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.11
		cVrDetAverageMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				averagingOff(1),
				averagingOn(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Broadband detector's averaging status:
				1 = averaging off
				2 = averaging on"
			::= { cVrEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.12
		cVrRfLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF level status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { cVrEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.13
		cVrTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { cVrEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.14
		cVrForwardFrequencyMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				fwd862(1),
				fwd1g2(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKC670: Forward path mode:
				1 = 862 MHz
				2 = 1.2 GHz"
			::= { cVrEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.3.1.15
		cVrReturnFrequencyMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				ret65(1),
				ret204(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"BKC670: Return path mode (detected diplexer):
				1 = 65 MHz
				2 = 204 MHz"
			::= { cVrEntry 15 }

		
-- rwSVrTable contains element specific information for
-- return amplifier (BKR100/200) modules in a BK
-- system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.4
		rwSVrTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RwSVrEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"rwSVrTable contains element specific information for
				return amplifier (BKR100/200) modules in a BK system."
			::= { bkModules1 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1
		rwSVrEntry OBJECT-TYPE
			SYNTAX RwSVrEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { rwSVrTable 1 }

		
		RwSVrEntry ::=
			SEQUENCE { 
				rwSVrGain
					Int16,
				rwSVrSlope
					Int16,
				rwSVrEqualiserType
					INTEGER,
				rwSVrGainSlopeMode
					INTEGER,
				rwSVrC1PortMode
					INTEGER,
				rwSVrC2PortMode
					INTEGER,
				rwSVrA1PortMode
					INTEGER,
				rwSVrA2PortMode
					INTEGER,
				rwSVrA3PortMode
					INTEGER,
				rwSVrNominalPortControl
					INTEGER,
				rwSVrPortStatus
					INTEGER,
				rwSVrTemperatureStatus
					INTEGER,
				rwSVrNotchControl
					INTEGER,
				rwSVrA4PortMode
					INTEGER,
				rwSVrFrequencyMode
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.3.4.1.1
		rwSVrGain OBJECT-TYPE
			SYNTAX Int16 (-800..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value. Unit 0.01 dB."
			::= { rwSVrEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.2
		rwSVrSlope OBJECT-TYPE
			SYNTAX Int16 (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value. Unit 0.01 dB."
			::= { rwSVrEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.3
		rwSVrEqualiserType OBJECT-TYPE
			SYNTAX INTEGER
				{
				eqTerm(0),
				eqBKE000(1),
				eqBKE040(2),
				eqBKE100(4),
				eqBKE160(6),
				eqBKE220(8),
				eqBKE280(10),
				eqBKE340(12),
				eqBKE400(14),
				eqBKE605(15),
				eqBKE610(16),
				eqBKE614(17),
				eqBKE618(18),
				eqBKE622(19),
				eqBKE626orBKZ070(20),
				eqBKE630orBKZ081(21),
				eqOTR(22),
				eqBKE634orBKZ092(23),
				eqBKE638orBKZ103(24),
				eqBKE642orBKZ114(25),
				eqOpen(26),
				eqNotDetected(27),
				eqOther(28),
				eqBKE14(100),
				eqBKE28(101),
				eqBKE42(102),
				eqBKE148(103),
				eqBKE288(104),
				eqBKE428(105),
				eqBKE003(113)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Detected cable equaliser type indicator (from AVr):
				0  = Terminated
				1  = BKE000
				2  = BKE040
				4  = BKE100
				6  = BKE160
				8  = BKE220
				10 = BKE280
				12 = BKE340
				14 = BKE400
				15 = BKE605
				16 = BKE610
				17 = BKE614
				18 = BKE618
				19 = BKE622
				20 = BKE626 or BKZ070
				21 = BKE630 or BKZ081
				22 = OTR
				23 = BKE634 or BKZ092
				24 = BKE638 or BKZ103
				25 = BKE642 or BKZ114
				26 = Open
				27 = equaliser not detected
				28 = other equaliser type detected
				100 = BKE14
				101 = BKE28
				102 = BKE42
				103 = BKE148
				104 = BKE288
				105 = BKE428
				113 = BKE003
				Can be written only when rAmpGainSlopeMode is set to
				2 (= based on manual equaliser selection)."
			::= { rwSVrEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.4
		rwSVrGainSlopeMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				controlManual(1),
				controlEquMan(2),
				controlEquAuto(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain and slope control mode:
				1 = manual gain and slope control
				2 = based on manual equaliser selection
				3 = based on automatic equaliser selection."
			::= { rwSVrEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.5
		rwSVrC1PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3),
				inputDisabled(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKR200: Port RC1 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB (off)
				
				BKR100: Port RC1 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB (off)
				4 = disabled (-50 dB without notification)"
			::= { rwSVrEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.6
		rwSVrC2PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3),
				inputDisabled(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKR200: Port RC2 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB (off)
				
				BKR100: Port RC2 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB (off)
				4 = disabled (-50 dB without notification)"
			::= { rwSVrEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.7
		rwSVrA1PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKR200: Port RA1 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB
				
				BKR100: Port RA mode control:
				1 = 0 dB
				2 = - 6 dB"
			::= { rwSVrEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.8
		rwSVrA2PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Port RA2 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB
				
				With BKR100 this object is read only. Returned value is
				always 3 (input50dB)."
			::= { rwSVrEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.9
		rwSVrA3PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Port RA3 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB
				
				With BKR100 this object is read only. Returned value is
				always 3 (input50dB)."
			::= { rwSVrEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.10
		rwSVrNominalPortControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				returnToNominal(1),
				defineAsNominal(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"This object controls the return path switches 'nominal'
				setting. Any combination of the switch positions can be
				defined as the 'nominal' setting. A reminder alarm
				will be initiated if any of the switches is not in it's
				nominal position.
				
				Set operations:
				1 = returnToNominal, returns all switches to their nominal
				    positions
				2 = defineNominal, stores the current port configuration
				    as the nominal configuration. 
				
				Get operations
				1 = all switches are in their nominal positions
				2 = one or more switches is not in it's nominal position
				
				Note: Immediately after a set (1 or 2), the return value 
				will be 1 meaning that the switches are in their nominal
				positions.
				
				With BKR100 this object is read only. Returned value is
				always 1 (returnToNominal)."
			::= { rwSVrEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.11
		rwSVrPortStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				portsNominal(1),
				portsNotNominal(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Status of return path switches:
				1 = all switches are in their nominal positions
				2 = one or more switches is not in it's nominal position
				
				With BKR100 this object always returns 1 (portsNominal)."
			::= { rwSVrEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.12
		rwSVrTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { rwSVrEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.13
		rwSVrNotchControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				notchDisable(1),
				notchEnable(2)
				}
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Control of the 65 MHz notch in BKR300:
				1(notchDisable) = notch OFF
				2(notchEnable) = notch ON"
			::= { rwSVrEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.14
		rwSVrA4PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKR700: Port RA4 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB
				"
			::= { rwSVrEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.4.1.15
		rwSVrFrequencyMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				ret65(1),
				ret204(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKR700: Return path mode:
				1 = 65 MHz
				2 = 204 MHz"
			::= { rwSVrEntry 15 }

		
-- aVrTable contains element specific information for
-- trunk amplifier (BKT60X/61X/80X) modules in a BK
-- system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.5
		aVrTable OBJECT-TYPE
			SYNTAX SEQUENCE OF AVrEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"aVrTable contains element specific information for
				trunk amplifier (BKT60X/61X/80X) modules in a BK system."
			::= { bkModules1 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1
		aVrEntry OBJECT-TYPE
			SYNTAX AVrEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { aVrTable 1 }

		
		AVrEntry ::=
			SEQUENCE { 
				aVrGain
					Int16,
				aVrSlope
					Int16,
				aVrHighPilotLevel
					Uint16,
				aVrHighPilotTargetLevel
					Uint16,
				aVrHighPilotRefMode
					INTEGER,
				aVrHighPilotLevelHiHi
					Uint16,
				aVrHighPilotLevelHi
					Uint16,
				aVrHighPilotLevelLo
					Uint16,
				aVrHighPilotLevelLoLo
					Uint16,
				aVrHighPilotLevelDeadband
					Uint16,
				aVrAlscMode
					INTEGER,
				aVrAlscPilotLostMode
					INTEGER,
				aVrOperationMode
					INTEGER,
				aVrCurrentInput
					INTEGER,
				aVrMainEqualiserType
					INTEGER,
				aVrBackupEqualiserType
					INTEGER,
				aVrGainStatus
					INTEGER,
				aVrSlopeStatus
					INTEGER,
				aVrBackupStatus
					INTEGER,
				aVrHighPilotLevelStatus
					INTEGER,
				aVrTemperatureStatus
					INTEGER,
				aVrLowPilotLevel
					Uint16,
				aVrLowPilotTargetLevel
					Uint16,
				aVrLowPilotRefMode
					INTEGER,
				aVrLowPilotLevelHiHi
					Uint16,
				aVrLowPilotLevelHi
					Uint16,
				aVrLowPilotLevelLo
					Uint16,
				aVrLowPilotLevelLoLo
					Uint16,
				aVrLowPilotLevelDeadband
					Uint16,
				aVrLowPilotLevelStatus
					INTEGER,
				aVrAlscControlStatus
					INTEGER,
				aVrEqualiserStatus
					INTEGER,
				aVrAlscStatus
					INTEGER,
				aVrLowEndPeak
					INTEGER,
				aVrHighPilotFrequency
					Uint16,
				aVrLowPilotFrequency
					Uint16
			 }

		-- 1.3.6.1.4.1.3715.3.3.5.1.1
		aVrGain OBJECT-TYPE
			SYNTAX Int16 (-600..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value. Unit 0.01 dB"
			::= { aVrEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.2
		aVrSlope OBJECT-TYPE
			SYNTAX Int16 (-400..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value. Unit 0.01 dB."
			::= { aVrEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.3
		aVrHighPilotLevel OBJECT-TYPE
			SYNTAX Uint16 (0..12000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured high pilot level. Unit 0.01 dBµV."
			::= { aVrEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.4
		aVrHighPilotTargetLevel OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot target level. The ALSC system always
				tries to adjust gain and slope to set the pilot
				levels to target. Unit 0.01 dBµV."
			::= { aVrEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.5
		aVrHighPilotRefMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				refFactory(1),
				refUser(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level reference value in use:
				1 = factory set reference
				2 = custom reference"
			::= { aVrEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.6
		aVrHighPilotLevelHiHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level high alarm limit. Unit 0.01 dBµV."
			::= { aVrEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.7
		aVrHighPilotLevelHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level high warning limit. Unit 0.01 dBµV."
			::= { aVrEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.8
		aVrHighPilotLevelLo OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level low warning limit. Unit 0.01 dBµV."
			::= { aVrEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.9
		aVrHighPilotLevelLoLo OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level low alarm limit. Unit 0.01 dBµV."
			::= { aVrEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.10
		aVrHighPilotLevelDeadband OBJECT-TYPE
			SYNTAX Uint16 (50..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"High pilot level deadband. Unit 0.01 dBµV."
			::= { aVrEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.11
		aVrAlscMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				alscOff(1),
				alscSinglePilot(2),
				alscDoublePilot(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"ALSC operating mode:
				1 = ALSC off
				2 = ALSC on, single pilot mode
				3 = ALSC on, double pilot mode
				"
			::= { aVrEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.12
		aVrAlscPilotLostMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				alscFreeze(1),
				alscStart(2),
				alscFactory(3),
				alscUser(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain and Slope control behaviour when the pilot
				is lost:
				1 = freeze to current positions
				2 = go to ALSC start settings
				3 = go to factory defaults
				4 = go to user defined settings"
			::= { aVrEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.13
		aVrOperationMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputAutomatic(1),
				inputMain(2),
				inputBackup(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Input switch operating mode:
				1 = automatic
				2 = main input
				3 = backup input"
			::= { aVrEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.14
		aVrCurrentInput OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputMain(1),
				inputBackup(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Currently selected input:
				1 = main input
				2 = backup input"
			::= { aVrEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.15
		aVrMainEqualiserType OBJECT-TYPE
			SYNTAX INTEGER
				{
				eqTerm(0),
				eqBKE000(1),
				eqBKE040(2),
				eqBKE100(4),
				eqBKE160(6),
				eqBKE220(8),
				eqBKE280(10),
				eqBKE340(12),
				eqBKE400(14),
				eqBKE605(15),
				eqBKE610(16),
				eqBKE614(17),
				eqBKE618(18),
				eqBKE622(19),
				eqBKE626orBKZ070(20),
				eqBKE630orBKZ081(21),
				eqOTR(22),
				eqBKE634orBKZ092(23),
				eqBKE638orBKZ103(24),
				eqBKE642orBKZ114(25),
				eqOpen(26),
				eqBKE14(100),
				eqBKE28(101),
				eqBKE42(102),
				eqBKE148(103),
				eqBKE288(104),
				eqBKE428(105),
				eqBKE003(113)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Main input cable equaliser type indicator:
				0  = Terminated
				1  = BKE000
				2  = BKE040
				4  = BKE100
				6  = BKE160
				8  = BKE220
				10 = BKE280
				12 = BKE340
				14 = BKE400
				15 = BKE605
				16 = BKE610
				17 = BKE614
				18 = BKE618
				19 = BKE622
				20 = BKE626 or BKZ070
				21 = BKE630 or BKZ081
				22 = OTR
				23 = BKE634 or BKZ092
				24 = BKE638 or BKZ103
				25 = BKE642 or BKZ114
				26 = Open
				100 = BKE14
				101 = BKE28
				102 = BKE42
				103 = BKE148
				104 = BKE288
				105 = BKE428
				113 = BKE003"
			::= { aVrEntry 15 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.16
		aVrBackupEqualiserType OBJECT-TYPE
			SYNTAX INTEGER
				{
				eqTerm(0),
				eqBKE000(1),
				eqBKE040(2),
				eqBKE100(4),
				eqBKE160(6),
				eqBKE220(8),
				eqBKE280(10),
				eqBKE340(12),
				eqBKE400(14),
				eqBKE605(15),
				eqBKE610(16),
				eqBKE614(17),
				eqBKE618(18),
				eqBKE622(19),
				eqBKE626orBKZ070(20),
				eqBKE630orBKZ081(21),
				eqOTR(22),
				eqBKE634orBKZ092(23),
				eqBKE638orBKZ103(24),
				eqBKE642orBKZ114(25),
				eqOpen(26)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Backup input cable equaliser type indicator:
				0  = Terminated
				1  = BKE000
				2  = BKE040
				4  = BKE100
				6  = BKE160
				8  = BKE220
				10 = BKE280
				12 = BKE340
				14 = BKE400
				15 = BKE605
				16 = BKE610
				17 = BKE614
				18 = BKE618
				19 = BKE622
				20 = BKE626 or BKZ070
				21 = BKE630 or BKZ081
				22 = OTR
				23 = BKE634 or BKZ092
				24 = BKE638 or BKZ103
				25 = BKE642 or BKZ114
				26 = Open
				"
			::= { aVrEntry 16 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.17
		aVrGainStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				gainNormal(1),
				gainMaximum(2),
				gainMinimum(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Gain control status in ALSC mode:
				1 = normal
				2 = maximum
				3 = minimum
				"
			::= { aVrEntry 17 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.18
		aVrSlopeStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				slopeNormal(1),
				slopeMaximum(2),
				slopeMinimum(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Slope control status in ALSC mode:
				1 = normal
				2 = maximum
				3 = minimum
				"
			::= { aVrEntry 18 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.19
		aVrBackupStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				backupInactive(1),
				backupActive(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Backup input status:
				1 = backup input inactive
				2 = backup input active"
			::= { aVrEntry 19 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.20
		aVrHighPilotLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"High pilot level status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { aVrEntry 20 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.21
		aVrTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { aVrEntry 21 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.22
		aVrLowPilotLevel OBJECT-TYPE
			SYNTAX Uint16 (0..12000)
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Measured low pilot level. Unit 0.01 dBµV."
			::= { aVrEntry 22 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.23
		aVrLowPilotTargetLevel OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot target level. The ALSC system always
				tries to adjust gain and slope to set the pilot
				levels to target. Unit 0.01 dBµV."
			::= { aVrEntry 23 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.24
		aVrLowPilotRefMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				refFactory(1),
				refUser(2)
				}
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level reference value in use:
				1 = factory set reference
				2 = custom reference"
			::= { aVrEntry 24 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.25
		aVrLowPilotLevelHiHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level high alarm limit. Unit 0.01 dBµV."
			::= { aVrEntry 25 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.26
		aVrLowPilotLevelHi OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level high warning limit. Unit 0.01 dBµV."
			::= { aVrEntry 26 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.27
		aVrLowPilotLevelLo OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level low warning limit. Unit 0.01 dBµV."
			::= { aVrEntry 27 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.28
		aVrLowPilotLevelLoLo OBJECT-TYPE
			SYNTAX Uint16 (0..10000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level low alarm limit. Unit 0.01 dBµV."
			::= { aVrEntry 28 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.29
		aVrLowPilotLevelDeadband OBJECT-TYPE
			SYNTAX Uint16 (50..1000)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Low pilot level deadband. Unit 0.01 dBµV."
			::= { aVrEntry 29 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.30
		aVrLowPilotLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Low pilot level status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { aVrEntry 30 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.31
		aVrAlscControlStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				controlsNormal(1),
				controlsCloseToLimits(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Status of ALSC controls:
				1 = Gain and slope controls are within normal operating
				    values
				2 = Gain or slope control is close to maximum/minimum
				    value
				"
			::= { aVrEntry 31 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.32
		aVrEqualiserStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				eqDetNormal(1),
				eqDetFailure(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Status of the equaliser detection cirsuit:
				1 = both equalisers are detected normally
				2 = one or both equalisers can not be detected
				"
			::= { aVrEntry 32 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.33
		aVrAlscStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				alscNormal(1),
				alscSinglePilot(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Double pilot ALSC status:
				1 = ALSC is working normally or is OFF
				2 = ALSC is in single pilot mode due to missing pilot
				    (slope control is frozen)
				
				"
			::= { aVrEntry 33 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.34
		aVrLowEndPeak OBJECT-TYPE
			SYNTAX INTEGER
				{
				peakOff(1),
				peakOn(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Control of the low end (85 MHz) peaking:
				1 = low end peak OFF (BKT690: 250 MHz peak on)
				2 = low end peak ON (BKT690: 85 MHz peak on)"
			::= { aVrEntry 34 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.35
		aVrHighPilotFrequency OBJECT-TYPE
			SYNTAX Uint16 (0..12000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKT690: High pilot frequency. Unit 0.25 MHz."
			::= { aVrEntry 35 }

		
		-- 1.3.6.1.4.1.3715.3.3.5.1.36
		aVrLowPilotFrequency OBJECT-TYPE
			SYNTAX Uint16 (0..12000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"BKT690: Low pilot frequency. Unit 0.25 MHz."
			::= { aVrEntry 36 }

		
-- oTrTable contains element specific information for
-- optical transceiver (BKO900/BOX860) modules in a BK
-- system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.6
		oTrTable OBJECT-TYPE
			SYNTAX SEQUENCE OF OTrEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"oTrTable contains element specific information for
				optical transceiver (BKO900/BOX860) modules in a BK
				system."
			::= { bkModules1 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1
		oTrEntry OBJECT-TYPE
			SYNTAX OTrEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { oTrTable 1 }

		
		OTrEntry ::=
			SEQUENCE { 
				oTrRxPower
					Int16,
				oTrRxPowerHiHi
					Int16,
				oTrRxPowerHi
					Int16,
				oTrRxPowerLo
					Int16,
				oTrRxPowerLoLo
					Int16,
				oTrRxPowerDeadband
					Uint16,
				oTrRxOutputState
					INTEGER,
				oTrRxOutputMode
					INTEGER,
				oTrRxRfOutDcSettings
					INTEGER,
				oTrTxPower
					Uint16,
				oTrTxPowerLo
					Int16,
				oTrTxPowerLoLo
					Int16,
				oTrTxPowerDeadband
					Uint16,
