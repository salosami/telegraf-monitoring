			DESCRIPTION
				"necTable contains element specific information for
				Network Element Controller (BKC90X) modules in a BK
				system."
			::= { bkModules1 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1
		necEntry OBJECT-TYPE
			SYNTAX NecEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { necTable 1 }

		
		NecEntry ::=
