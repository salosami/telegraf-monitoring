		-- 1.3.6.1.4.1.3715.3.3.1.1.8
		necModemTxFrequency OBJECT-TYPE
			SYNTAX Uint16 (500..1500)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Modem transmit frequency. Unit 10 kHz."
			::= { necEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.9
		necModemTxLevelMin OBJECT-TYPE
			SYNTAX Uint16 (7300..9000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Modem minimum transmit level. Unit 0.01 dBµV.
				
				The module limits the values to the specified range as follows:
				
				BKC902: The accepted range is 8000-9000 (80-90 dBuV). If a Set message
				contains a value outside this range, a 'Bad value' is returned and the
				current value is maintained.
				
				BKC903: The accepted range is 7300-8300 (73-83 dBuV). If a Set message
				contains a value outside this range, the module sets the value to the 
				corresponding limit.
				
				For a fixed level setting, the minimum and maximum transmit level values
				should equal."
			::= { necEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.10
		necModemTxLevelMax OBJECT-TYPE
			SYNTAX Uint16 (7300..9000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Modem maximum transmit level. Unit 0.01 dBµV.
				
				The module limits the values to the specified range as follows:
				
				BKC902: The accepted range is 8000-9000 (80-90 dBuV). If a Set message
				contains a value outside this range, a 'Bad value' is returned and the
				current value is maintained.
				
				BKC903: The accepted range is 7300-8300 (73-83 dBuV). If a Set message
				contains a value outside this range, the module sets the value to the 
				corresponding limit.
				
				For a fixed level setting, the minimum and maximum transmit level values
				should equal."
			::= { necEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.11
		necModemRegState OBJECT-TYPE
			SYNTAX INTEGER
				{
				regSettingRx(1),
				regNoCarrier(2),
				regWaitChannelInfo(3),
				regSettingTxFreq(4),
				regTxStabilisation(5),
				regSettingTxLevel(6),
				regPreparing(7),
				regStarting(8),
				regInProgress(9),
				regWaitConfirm(10),
				regComplete(11)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Modem registration state:
				1 = setting RX frequency
				2 = no data carrier
				3 = waiting for channel infor (CHNLDESC)
				4 = setting TX frequency
				5 = waiting for TX stabilisation
				6 = setting TX level
				7 = preparing registration
				8 = registration starting
				9 = registration in progress
				10 = waiting for confimation
				11 = registration complete"
			::= { necEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.12
		necModemReceived OBJECT-TYPE
			SYNTAX Uint16
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of received non-MAC datagrams."
			::= { necEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.13
		necModemBad OBJECT-TYPE
			SYNTAX Uint16
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of received invalid non-MAC datagrams."
			::= { necEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.14
		necModemSent OBJECT-TYPE
			SYNTAX Uint16
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of sent non-MAC datagrams."
			::= { necEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.15
		necModemResetStat OBJECT-TYPE
			SYNTAX INTEGER
				{
				noReset(1),
				reset(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Reset modem statistics.
				1 = no effect
				2 = reset packet counters"
			::= { necEntry 15 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.16
		necModemChnlDescTimeout OBJECT-TYPE
			SYNTAX Uint16 (0..600)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Timeout for CHNLDESC. Unit 1 second.
				
				This is the time the modem waits for a valid CHNLDESC message
				from the HMTS. If the timeout is exceeded, the modem starts
				scanning for another HMS data channel.
				
				Timeout value 0 means the modem will wait an infinite time
				if it has found a signal with sufficient level."
			::= { necEntry 16 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.17
		necModemPollTimeout OBJECT-TYPE
			SYNTAX Uint16 (0..6000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Timeout for unicast messages. Unit 1 second.
				
				This is the time the modem waits for any messages to its
				unicast MAC address. If the timeout is exceeded, the modem
				starts the registration process to inform the HMTS about
				it's presence.
				
				Timeout 0 will disable poll checking (contention mode operation)."
			::= { necEntry 17 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.18
		necHwError OBJECT-TYPE
			SYNTAX INTEGER
				{
				hwOk(1),
				hwError(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module controller hardware status:
				1 = hardware OK
				2 = hardware error detected"
			::= { necEntry 18 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.19
		necRxLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF modem downstream receiver level status
				1 = normal
				3 = HI
				4 = LO"
			::= { necEntry 19 }

		
		-- 1.3.6.1.4.1.3715.3.3.1.1.20
		necTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { necEntry 20 }

		
