		-- 1.3.6.1.4.1.3715.3.3.6.1.1
		oTrRxPower OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver input power. Unit 0.01 dBm."
			::= { oTrEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.2
		oTrRxPowerHiHi OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver input power high alarm limit. Unit 0.01 dBm."
			::= { oTrEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.3
		oTrRxPowerHi OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver input power high warning limit. Unit 0.01 dBm."
			::= { oTrEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.4
		oTrRxPowerLo OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver input power low warning limit. Unit 0.01 dBm."
			::= { oTrEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.5
		oTrRxPowerLoLo OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver input power low alarm limit. Unit 0.01 dBm."
			::= { oTrEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.6
		oTrRxPowerDeadband OBJECT-TYPE
			SYNTAX Uint16 (20..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver input power deadband. Unit 0.01 dBm."
			::= { oTrEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.7
		oTrRxOutputState OBJECT-TYPE
			SYNTAX INTEGER
				{
				auxOff(1),
				bothOn(2),
				bothOff(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver output states:
				1 = aux (2) OFF
				2 = both ON
				3 = both OFF"
			::= { oTrEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.8
		oTrRxOutputMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				auto(1),
				bothOn(2),
				auxOff(3),
				bothOff(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver output mode:
				1 = automatic control
				2 = both ON
				3 = aux OFF
				4 = both OFF
				
				Note: BOX860 does not support value 4 = both off."
			::= { oTrEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.9
		oTrRxRfOutDcSettings OBJECT-TYPE
			SYNTAX INTEGER
				{
				rxOutDcIgnore(1),
				rxOutDcUse(2)
				}
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Output connector DC control voltage usage:
				1 = ignore DC voltage on output connector
				2 = use DC voltage (for controlling redundancy switching)"
			::= { oTrEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.10
		oTrTxPower OBJECT-TYPE
			SYNTAX Uint16 (0..600)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Transmitter output power. Unit 0.01 dBm."
			::= { oTrEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.11
		oTrTxPowerLo OBJECT-TYPE
			SYNTAX Int16 (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter output power low warning limit. Unit 0.01 dBm."
			::= { oTrEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.12
		oTrTxPowerLoLo OBJECT-TYPE
			SYNTAX Int16 (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter output power low alarm limit. Unit 0.01 dBm."
			::= { oTrEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.13
		oTrTxPowerDeadband OBJECT-TYPE
			SYNTAX Uint16 (20..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter output power deadband. Unit 0.01 dBm."
			::= { oTrEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.14
		oTrTxOmi OBJECT-TYPE
			SYNTAX Uint16 (350..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical modulation index control value. Unit 0.01 %."
			::= { oTrEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.15
		oTrTxFibreNumber OBJECT-TYPE
			SYNTAX INTEGER (0..999)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Fibre node number. The transmitter sends the fibre node number
				with the pilot. At the receiver the number can be used to identify
				the correct fibre. Range 1...999, zero = no number entered."
			::= { oTrEntry 15 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.16
		oTrTxMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				txModeSleep(1),
				txModeNormal(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter operating mode:
				1 = deep sleep mode (output power -6dB)
				2 = normal mode"
			::= { oTrEntry 16 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.17
		oTrTxPilotMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				pilotOff(1),
				pilotOn(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter pilot mode:
				1 = Pilot off
				2 = Pilot on"
			::= { oTrEntry 17 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.18
		oTrTxInputState OBJECT-TYPE
			SYNTAX INTEGER
				{
				auxOff(1),
				bothOn(2),
				bothOff(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Transmitter input state:
				1 = aux (2) OFF
				2 = both ON
				3 = both OFF"
			::= { oTrEntry 18 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.19
		oTrTxInputMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				auto(1),
				bothOn(2),
				auxOff(3),
				bothOff(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter input mode:
				1 = automatic control
				2 = both ON
				3 = aux OFF
				4 = both OFF"
			::= { oTrEntry 19 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.20
		oTrLaserCurrentRel OBJECT-TYPE
			SYNTAX Uint16 (0..15000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser current relative to factory set laser current.
				Unit 0.01 %."
			::= { oTrEntry 20 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.21
		oTrLaserCurrentRelHi OBJECT-TYPE
			SYNTAX Uint16 (0..15000)
			ACCESS read-write
