				3 = - 50 dB (off)"
			::= { oTrEntry 56 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.57
		oTrTx22PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Port Tx22 mode control:
				1 = 0 dB
				2 = - 6 dB
				3 = - 50 dB (off)"
			::= { oTrEntry 57 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.58
		oTrNominalPortControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				returnToNominal(1),
				defineAsNominal(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"This object controls the return path switches 'nominal'
				setting. Any combination of the switch positions can be
				defined as the 'nominal' setting. Alarm is activated if
				any of the switches is not in its nominal position.
				
				Set operations:
				1 = returnToNominal, returns all switches to their nominal positions
				2 = defineNominal, stores the current port configuration as the nominal configuration. 
				
				Get operations
				1 = all switches are in their nominal positions
				2 = one or more switches is not in it's nominal position"
			::= { oTrEntry 58 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.59
		oTrRxGain OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver gain control value. Unit 0.01 dB."
			::= { oTrEntry 59 }

		
		-- 1.3.6.1.4.1.3715.3.3.6.1.60
		oTrTx2Gain OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Transmitter 2 gain control value. Unit 0.01 dB."
			::= { oTrEntry 60 }

		
-- oRxTable contains element specific information for
-- optical receiver (BOR1000) modules in a BK
-- system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.7
		oRxTable OBJECT-TYPE
			SYNTAX SEQUENCE OF ORxEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"oRxTable contains element specific information for
				optical receiver (BOR1000) modules in a BK system."
			::= { bkModules1 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1
		oRxEntry OBJECT-TYPE
			SYNTAX ORxEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { oRxTable 1 }

		
		ORxEntry ::=
			SEQUENCE { 
				oRxInputPower
					Int16,
				oRxInputPowerHiHi
					Int16,
				oRxInputPowerHi
					Int16,
				oRxInputPowerLo
					Int16,
				oRxInputPowerLoLo
					Int16,
				oRxInputPowerDeadband
					Uint16,
				oRxActivity
					INTEGER,
				oRxInputPowerStatus
					INTEGER,
				oRxOutputLevelOffset
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.3.7.1.1
		oRxInputPower OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical input power. Unit 0.01 dBm."
			::= { oRxEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.2
		oRxInputPowerHiHi OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power high alarm limit. Unit 0.01 dBm."
			::= { oRxEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.3
		oRxInputPowerHi OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power high warning limit. Unit 0.01 dBm."
			::= { oRxEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.4
		oRxInputPowerLo OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power low warning limit. Unit 0.01 dBm."
			::= { oRxEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.5
		oRxInputPowerLoLo OBJECT-TYPE
			SYNTAX Int16 (-2000..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power low alarm limit. Unit 0.01 dBm."
			::= { oRxEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.6
		oRxInputPowerDeadband OBJECT-TYPE
			SYNTAX Uint16 (20..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power deadband. Unit 0.01 dBm."
			::= { oRxEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.7
		oRxActivity OBJECT-TYPE
			SYNTAX INTEGER
				{
				rxSleeping(1),
				rxActive(2)
				}
			ACCESS read-only
			STATUS optional
			DESCRIPTION
				"Receiver activity:
				1 = sleeping
				2 = active"
			::= { oRxEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.8
		oRxInputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical input power status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oRxEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.7.1.9
		oRxOutputLevelOffset OBJECT-TYPE
			SYNTAX INTEGER (-1250..1250)
			ACCESS read-write
			STATUS optional
			DESCRIPTION
				"Output RF level offset. Unit 0.01 dB, 
				value range -1250...1250 (-12.5 dB to +12.5 dB)."
			::= { oRxEntry 9 }

		
-- sEqTable contains element specific information for
-- System Equaliser (BKE90X) modules in a BK system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
		-- 1.3.6.1.4.1.3715.3.3.10
		sEqTable OBJECT-TYPE
			SYNTAX SEQUENCE OF SEqEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"sEqTable contains element specific information for
				System Equaliser (BKE90X) modules in a BK system."
			::= { bkModules1 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1
		sEqEntry OBJECT-TYPE
			SYNTAX SEqEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { sEqTable 1 }

		
		SEqEntry ::=
			SEQUENCE { 
				sEqControl
					INTEGER,
				sEqGain
					INTEGER,
				sEqCableCurve
					INTEGER,
				sEqPeak1Gain
					INTEGER,
				sEqPeak2Frequency
					INTEGER,
				sEqPeak2Gain
					INTEGER,
				sEqNotch1Frequency
					INTEGER,
				sEqNotch1Gain
					INTEGER,
				sEqNotch2Frequency
					INTEGER,
				sEqNotch2Gain
					INTEGER,
				sEqPeak3Gain
					INTEGER,
				sEqStatus
					INTEGER,
				sEqPeak4Frequency
					INTEGER,
				sEqPeak4Gain
					INTEGER,
				sEqNetworkType
					INTEGER,
				sEqNotch2FreqRange
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.3.10.1.1
		sEqControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				storeAsNominal(1),
				revertToNominal(2),
				revertToFlat(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Equaliser common control:
				1 = store current settings as nominal setting
				2 = revert to nominal settings
				3 = revert to flat settings"
			::= { sEqEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.2
		sEqGain OBJECT-TYPE
			SYNTAX INTEGER (-400..150)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Flat gain/attenuation of the module. Unit 0.01 dB."
			::= { sEqEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.3
		sEqCableCurve OBJECT-TYPE
			SYNTAX INTEGER (-120..120)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Cable curve correction value. Unit 0.01 dB."
			::= { sEqEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.4
		sEqPeak1Gain OBJECT-TYPE
			SYNTAX INTEGER (0..140)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of low band edge (85 MHz) equaliser. Unit 0.01 dB.
				- BKE900/BKE901: 0 dB/1 dB
				- BKE902: 0 dB/1.4 dB
				"
			::= { sEqEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.5
		sEqPeak2Frequency OBJECT-TYPE
			SYNTAX INTEGER (1300..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Centre frequency of peak equaliser 2. Unit 0.1 MHz.
				Product specific adjustment ranges:
				- BKE900: 130...160 MHz
				- BKE901/BKE902: 130...300 MHz"
			::= { sEqEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.6
		sEqPeak2Gain OBJECT-TYPE
			SYNTAX INTEGER (0..160)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of peak equaliser 2. Unit 0.01 dB."
			::= { sEqEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.7
		sEqNotch1Frequency OBJECT-TYPE
			SYNTAX INTEGER (2200..2800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Centre frequency of notch equaliser 1. Unit 0.1 MHz."
			::= { sEqEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.8
		sEqNotch1Gain OBJECT-TYPE
			SYNTAX INTEGER (-100..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of notch equaliser 1. Unit 0.01 dB."
			::= { sEqEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.9
		sEqNotch2Frequency OBJECT-TYPE
			SYNTAX INTEGER (4000..5200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Centre frequency of notch equaliser 1. Unit 0.1 MHz.
				Product specific adjustment ranges:
				- BKE900: 400...450 MHz
				- BKE901: 400...470 MHz
				- BKE901 G02Ä00/BKE902: 450...520 MHz"
			::= { sEqEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.10
		sEqNotch2Gain OBJECT-TYPE
			SYNTAX INTEGER (-140..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of notch equaliser 2. Unit 0.01 dB.
				"
			::= { sEqEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.11
		sEqPeak3Gain OBJECT-TYPE
			SYNTAX INTEGER (0..150)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of peak equaliser 3. Unit 0.01 dB.
				Product specific fixed centre frequency:
				- BKE900: 555 MHz
				- BKE901: 511 MHz
				- BKE902: 170 MHz"
			::= { sEqEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.12
		sEqStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				nominal(1),
				notNominal(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Equaliser status:
				1 = settings in nominal state
				2 = settings not in nominal state
				This object has an entry in the discretePropertyTable."
			::= { sEqEntry 12 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.13
		sEqPeak4Frequency OBJECT-TYPE
			SYNTAX INTEGER (6800..8600)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Centre frequency of peak equaliser 4. Unit 0.1 MHz.
				Available only with BKE901 and BKE902."
			::= { sEqEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.14
		sEqPeak4Gain OBJECT-TYPE
			SYNTAX INTEGER (0..160)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain/attenuation value of peak equaliser 4. Unit 0.01 dB.
				Available only with BKE901 and BKE902."
			::= { sEqEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.15
		sEqNetworkType OBJECT-TYPE
			SYNTAX INTEGER
				{
				bkt601and612and604(1),
				bkt612and605(2),
				bkt605(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Type of network where BKE901/BKE902 is used:
				1 = BKT601/BKT612/BKT604
				2 = BKT612/BKT605
				3 = BKT605"
			::= { sEqEntry 15 }

		
		-- 1.3.6.1.4.1.3715.3.3.10.1.16
		sEqNotch2FreqRange OBJECT-TYPE
			SYNTAX INTEGER
				{
				oldRange(0),
				newRange(1)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Notch equaliser 2 frequency range:
				0 = old range (400...470 MHz)
				1 = new range (450...520 MHz)"
			::= { sEqEntry 16 }

		
-- strVGtTable contains element specific information for
-- power supply (BKP065) modules in a BK system.
-- 
-- Note that index is moduleIndex which is column in 
-- the moduleTable defined in TELESTE-COMMON-MIB. Rows in
-- this table exist only if there are corresponding
-- rows in the moduleTable.
-- 
		-- 1.3.6.1.4.1.3715.3.3.11
		strVGtTable OBJECT-TYPE
			SYNTAX SEQUENCE OF StrVGtEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"strVGtTable contains element specific information for
				power supply (BKP065) modules in a BK system."
			::= { bkModules1 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1
		strVGtEntry OBJECT-TYPE
			SYNTAX StrVGtEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { moduleId }
			::= { strVGtTable 1 }

		
		StrVGtEntry ::=
			SEQUENCE { 
				strVGtInputVoltage
					INTEGER,
				strVGtInputCurrent
					INTEGER,
				strVGtOutputVoltage
					INTEGER,
				strVGtOutputCurrent
					INTEGER,
				strVGtInputVoltageStatus
					INTEGER,
				strVGtOutputVoltageStatus
					INTEGER,
				strVGtOutputCurrentStatus
					INTEGER,
				strVGtTemperatureStatus
					INTEGER,
				strVGtLastPacketTime
					INTEGER,
				strVGtInternalData
					OCTET STRING
			 }

		-- 1.3.6.1.4.1.3715.3.3.11.1.1
		strVGtInputVoltage OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured input voltage, RMS value. Unit 0.01 V."
			::= { strVGtEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.2
		strVGtInputCurrent OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Calculated/estimated input current, RMS value. Unit 0.01 A."
			::= { strVGtEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.3
		strVGtOutputVoltage OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured output voltage, DC value. Unit 0.01 V."
			::= { strVGtEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.4
		strVGtOutputCurrent OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured output current, DC value. Unit 0.01 A."
			::= { strVGtEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.11
		strVGtInputVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				voltageNormal(1),
				voltageHIHI(2),
				voltageHI(3),
				voltageLO(4),
				voltageLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input voltage status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { strVGtEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.13
		strVGtOutputVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				voltageNormal(1),
				voltageHIHI(2),
				voltageHI(3),
				voltageLO(4),
				voltageLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output voltage status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { strVGtEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.14
		strVGtOutputCurrentStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				currentNormal(1),
				currentHIHI(2),
				currentHI(3),
				currentLO(4),
				currentLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output current status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { strVGtEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.15
		strVGtTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { strVGtEntry 15 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.20
		strVGtLastPacketTime OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Time since last valid data packet from power supply. Unit 1 s."
			::= { strVGtEntry 20 }

		
		-- 1.3.6.1.4.1.3715.3.3.11.1.100
		strVGtInternalData OBJECT-TYPE
			SYNTAX OCTET STRING (SIZE (0..200))
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Copy of the binary data packet contents sent by the power supply."
			::= { strVGtEntry 100 }

		
		-- 1.3.6.1.4.1.3715.3.5
		bkd OBJECT IDENTIFIER ::= { bk 5 }

		
		-- 1.3.6.1.4.1.3715.3.5.200
		bkd200 OBJECT IDENTIFIER ::= { bkd 200 }

		
-- 
-- 
		-- 1.3.6.1.4.1.3715.3.5.200.1
		generation OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"BKD200 generation.
				1 = 1st generation."
			::= { bkd200 1 }

		
		-- 1.3.6.1.4.1.3715.3.5.200.2
		psu5V8 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"+5.8 VDC voltage from power supply. Unit 0.01 V.
				This object has an entry in the propertyTable."
			::= { bkd200 2 }

		
		-- 1.3.6.1.4.1.3715.3.5.200.3
		usTestpointSelection OBJECT-TYPE
			SYNTAX INTEGER
				{
				usTestpointSelectionAutomatic(1),
				usTestpointSelectionManualUS0(2),
				usTestpointSelectionManualUS1(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"US test point selection: 
				1: automatic, 
				2: manual US0, 
				3: manual US1
				"
			::= { bkd200 3 }

		
	
	END

--
-- TELESTE-BK-MIB.mib
--
