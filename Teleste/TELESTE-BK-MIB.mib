		-- 1.3.6.1.4.1.3715.3.3.6.1.56
		oTrTx21PortMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				inputOn(1),
				input6dB(2),
				input50dB(3)
				}
			ACCESS read-write
			STATUS mandatory
