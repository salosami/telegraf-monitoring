				acxPsu2StatusConnectionLost(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Power supply 2 status.
				1: OK
				2: Failure
				3: Power supply 2 status not available.
				4: Connection lost."
			::= { acxStation 13 }

		
		-- 1.3.6.1.4.1.3715.11.1.14
		acxPsu1Type OBJECT-TYPE
			SYNTAX INTEGER
