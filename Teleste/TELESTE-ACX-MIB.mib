		-- 1.3.6.1.4.1.3715.11.1.10
		acxPort3Usage OBJECT-TYPE
			SYNTAX INTEGER
				{
				portInputBypass(1),
				portOutput3(2),
				portNotAvailable(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF port 3 usage:
				1 = port 3 used as input bypass output
				2 = port 3 used as third output
				3 = the platform has no port 3 or the
				    information is not available from the hardware"
			::= { acxStation 10 }

		
		-- 1.3.6.1.4.1.3715.11.1.11
		acxModuleStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				statusNormal(1),
				statusUnknownModule(2),
				statusInternalError(3),
				statusNotPowered(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Status of modules installed on the ACx motherboard
				1 = all modules are properly identified
				2 = one or more unknown modules are present
				3 = internal error in motherboard
				4 = motherboard partially powered, no full functionality"
			::= { acxStation 11 }

		
		-- 1.3.6.1.4.1.3715.11.1.12
		acxPsu1Status OBJECT-TYPE
			SYNTAX INTEGER
				{
				acxPsu1StatusOk(1),
				acxPsu1StatusFailure(2),
				acxPsu1StatusNA(3),
				acxPsu1StatusConnectionLost(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Power supply 1 status.
				1: OK
				2: Failure
				3: Power supply 1 status not available.
				4: Connection lost."
			::= { acxStation 12 }

		
		-- 1.3.6.1.4.1.3715.11.1.13
