		-- 1.3.6.1.4.1.3715.11.9100.1
		ac9100alc3FollowsAlc1 OBJECT-TYPE
			SYNTAX INTEGER
				{
				alc3FollowsAlc1Enabled(1),
				alc3FollowsAlc1Disabled(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"AC9100, AC9100 NEO and AC9400 only.
				
				ALC special mode when ALC enabled: ALC 3 follows ALC 1. Only ALC 1 pilots are used. ALC 3 pilots are recommended to disable (set frequency to 0 MHz)."
			::= { ac9100 1 }

		
		-- 1.3.6.1.4.1.3715.11.9100.2
		ac9100NEO OBJECT IDENTIFIER ::= { ac9100 2 }

		
		-- 1.3.6.1.4.1.3715.11.9100.2.1
		ac9100neoReturnPathRfSplit OBJECT-TYPE
			SYNTAX INTEGER
				{
				returnPathSplitNone(0),
				returnPathSplitTx2toTx1(16),
				returnPathSplitTx4toTx3(16384),
				returnPathSplitTx2toTx1andTx4toTx3(16400)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return path RF split.
				
				Uint16 splitter to four bit groups 0xDCBA, where group is source (split from) A: Tx1, B: Tx2: C: Tx3, D: Tx4 
				and each bit group has bitmask of destination transmitters (split to) 0bklmn, where k: Tx4, l: Tx3, m: Tx2, n: Tx1. 
				Bit 0: not active/no split, bit 1: active/splitted.
				
				Example: Split Tx2 signal to Tx1: 0x0010. Example2: Split Tx4 signal to Tx3: 0x4000.
				
				Currently supported only four different combinationts.
				- No splits (0)
				- Split Tx2 to Tx1 (16)
				- Split Tx4 to Tx3 (16384)
				- Split Tx2 to Tx1 and Tx4 to Tx3 (16400)"
			::= { ac9100NEO 1 }

		
		-- 1.3.6.1.4.1.3715.11.9100.3
		ac9100alc3OffsetToAlc1 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"AC9100, AC9100 NEO and AC9400 only.
				
				Output3 offset. Unit 0.01 dB.
				
				When ac9100alc3FollowsAlc1 and ALC is enabled, then output 3 gain is ouput 1 gain + ac9100alc3OffsetToAlc1."
			::= { ac9100 3 }

		
		-- 1.3.6.1.4.1.3715.11.9400
		ac9400 OBJECT IDENTIFIER ::= { acx 9400 }

		
