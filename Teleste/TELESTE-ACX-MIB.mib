				acxPsu1TypeICON6300_FAIL(4),
				acxPsu1TypeNoPSU(8),
				acxPsu1TypeNA(15),
				acxPsu1TypeLuminatoPSU(16)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Detected power supply 1 type.
				2: ICON6300 PSU: Status OK
				4: ICON6300 PSU: One or more voltages failed.
				8: No PSU at this slot present.
				15: Device doesn't support automatic power supply type detection.
				16: Luminato PSU"
			::= { acxStation 14 }

		
