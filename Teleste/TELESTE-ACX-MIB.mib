		-- 1.3.6.1.4.1.3715.11.9400.2
		ac9400output12ModuleType OBJECT-TYPE
			SYNTAX INTEGER
				{
				outputModuleShort(1),
				outputModuleAC6124v1(2),
				outputModuleAC6124v2(3),
				outputModuleAC6113(4),
				outputModuleAC6114(5),
				outputModuleAC6115(6),
				outputModuleAC6117(7),
				outputModuleAC6120(12),
				outputModuleOpen(13),
				outputModuleReserved(14),
				outputModuleUnknown(15),
				outputModuleNA(16)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 1+2 output module type.
				 1: short
				 2: AC6124v1 (unknown module)
				 3: AC6124v2
				 4: AC6113
				 5: AC6114
				 6: AC6115
				 7: AC6117
				12: AC6120
				13: open
				14: reserved
				15: unknown
				16: N/A"
			::= { ac9400 2 }

		
		-- 1.3.6.1.4.1.3715.11.9400.3
		ac9400output34ModuleType OBJECT-TYPE
			SYNTAX INTEGER
				{
				outputModuleShort(1),
				outputModuleAC6124v1(2),
				outputModuleAC6124v2(3),
				outputModuleAC6113(4),
				outputModuleAC6114(5),
				outputModuleAC6115(6),
				outputModuleAC6117(7),
				outputModuleAC6120(12),
				outputModuleOpen(13),
				outputModuleReserved(14),
				outputModuleUnknown(15),
				outputModuleNA(16)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 3+4 output module type.
				 1: short
				 2: AC6124v1 (unknown module)
				 3: AC6124v2
				 4: AC6113
				 5: AC6114
				 6: AC6115
				 7: AC6117
				12: AC6120
				13: open
				14: reserved
				15: unknown
				16: N/A"
			::= { ac9400 3 }

		
		-- 1.3.6.1.4.1.3715.11.9400.4
		ac9400rpInputToOptTxSlotMapping OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Node return path RF input port -> optical transmitter slot # mapping. 
				xxxx yyyy zzzz wwww, where x=TxSlot 4…w=TxSlot1 and bits/nibble: dcba: d: RP input 1, c: RP input 3, b: RP input 2, a: RP input 1
				
				Examples
				RP input 2 to TxSlot 2: 0x0020
				RP input 1 and 3 to TxSlot 2 and 4: 0x5050
				"
			::= { ac9400 4 }

		
	
--
-- Trap definitions
--
	
		functionsDisabled TRAP-TYPE 
			ENTERPRISE acx
			VARIABLES { acxTransponderFunctionStatus }
			DESCRIPTION 
				"A notification that the functions are not running, which
				may mean that the programmable alarms are disabled.
				
				Possible reasons for the functions not running are:
				- the configuration is incompatible with the
				  programmed, or expected configuration
				- a hardware failure has occurred
				- a valid function set is not downloaded
				"
			::=  1

	
	END

