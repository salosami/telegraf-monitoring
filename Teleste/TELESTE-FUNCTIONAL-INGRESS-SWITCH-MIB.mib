			::= { ingressSwitchEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.3
		ingressSwitchAttenuationStepSize OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Attenuator step size. Unit 0.01 dB."
			::= { ingressSwitchEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.4
		ingressSwitchAttenuationStep OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Write:
				 	Attenuator step command.
				 	Value is number of steps to be stepped. Device performs step*stepSize step in decibels.
				 	If step < 0, element steps towards minimum.
				 	If step > 0, element steps towards maximum.
				 	
				 Read: 
				 	ingressSwitchAttenuation (unit 0.01 dB) after step commands. 
				 	So there's no need to read ingressSwitchAttenuation after step command to get the current value."
			::= { ingressSwitchEntry 4 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.5
		ingressSwitchAttenuationMinimumValue OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Minimum value of inress switch 'attenuator'. Unit 0.01 dB."
			::= { ingressSwitchEntry 5 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.6
		ingressSwitchAttenuationMaximumValue OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Maximum value of inress switch 'attenuator'. Unit 0.01 dB."
			::= { ingressSwitchEntry 6 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.7
		ingressSwitchControlMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				ingressSwitchControlModeAlarmAttenuate(1),
				ingressSwitchControlModeManual(2),
				ingressSwitchControlModeAlarmOff(3),
				ingressSwitchControlModeWarningAttenuateAlarmOff(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Ingress switch control mode.
				1: Ingress switch (ICS) is automatically switched to attenuation/padding (typically -6 dB) when ingress alarm is active.
				2: Ingress switch controlled manually.
				3: Ingress switch (ICS) is automatically switched to off (typically -50 dB) when ingress alarm is active.
				4: Ingress switch (ICS) is automatically switched to attenuation/padding (typically -6 dB) when ingress warning is active and 
				   Ingress switch (ICS) is automatically switched to off (typically -50 dB) when ingress alarm is active.
				
				
				See also ingressSwitchControlModeVersion for supported modes."
			::= { ingressSwitchEntry 7 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.8
		ingressSwitchActivationDelay OBJECT-TYPE
			SYNTAX INTEGER (0..65535)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Activation delay of the automatic ingress attenuation function.
