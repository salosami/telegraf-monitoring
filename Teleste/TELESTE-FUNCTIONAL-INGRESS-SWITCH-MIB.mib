		-- 1.3.6.1.4.1.3715.100.61.1.1.1
		ingressSwitchMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				on(1),
				off(2),
				attenuated(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return path ingress switch state:
				1 = low/on (0 dB/no attenuation)
				2 = high/off (>45 dB/full attenuation/return path cut off)
				3 = attenuated (pad)
				
				This object has an entry in the discretePropertyTable."
			::= { ingressSwitchEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.61.1.1.2
		ingressSwitchAttenuation OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
