				commonModemRegState11(11),
				commonModemRegState12(12),
				commonModemRegState13(13)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Modem registration state.
				
				CATVisor/HMS modem
				1: Reset
				2: Set receiver hardware to be ready
				3: Wait anypacket
				4: Wait RCD
				5: Transmitter setup time
				6: Set transmit level to hardware
				7: Send registration request
				8: Registration backoff time
				9: Wait registration acknowledgement
				10: Make status packet
				11: Connected/normal mode
				
				DOCSIS
				1: Other
				2: Not ready
				3: Not synchronized
				4: PHY synchronized
				5: US parameters acquired
				6: Ranging complete
				7: IP complete
				8: ToD established
				9: Security established
				10: Parameter transfer complete
				11: Registration complete
				12: Operational
				13: Access denied"
			::= { commonModemStatus 6 }

		
		-- 1.3.6.1.4.1.3715.100.7.1.7
		commonModemConnectionState OBJECT-TYPE
			SYNTAX INTEGER
