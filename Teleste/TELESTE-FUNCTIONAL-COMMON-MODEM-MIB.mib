				commonModemConnectionStateConnected(1),
				commonModemConnectionStateNotConnected(2),
				commonModemConnectionStateModemNotInstalled(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Modem connection state.
				1: Modem is connected.
				2: Modem is not connected.
				3: Modem not installed."
			::= { commonModemStatus 7 }

		
		-- 1.3.6.1.4.1.3715.100.7.1.8
		commonModemProtocol OBJECT-TYPE
			SYNTAX INTEGER
