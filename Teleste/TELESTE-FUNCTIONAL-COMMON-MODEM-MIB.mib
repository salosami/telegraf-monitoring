		-- 1.3.6.1.4.1.3715.100.7.1.6
		commonModemRegState OBJECT-TYPE
			SYNTAX INTEGER
				{
				commonModemRegState1(1),
				commonModemRegState2(2),
				commonModemRegState3(3),
				commonModemRegState4(4),
				commonModemRegState5(5),
