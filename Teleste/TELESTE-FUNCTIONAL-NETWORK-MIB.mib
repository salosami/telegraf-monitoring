-- Network interface type
-- 
-- 0x00	Not available
-- 0x01	Unknown
-- 0x06	Ethernet
-- 0x16	RPD Ethernet
-- 0x31	Atm Adaptation Layer 5
-- 0xe9	IP via Serial Port
-- 0xea	Legacy USB
-- (legacy TSEMP/DVX)
-- 0xeb	Routed USB
-- (both legacy TSEMP/DVX and new x/RSIP/DVX (e.g. TSEMP/RSIP/DVX and SNMP/RSIP/DVX)
-- 0xf6	RPD remote management
-- 0xf7	RPD local management
-- 0xf8	BK (Proxy)
-- 0xf9	DVX (Proxy)
-- 0xfa	RPD UART (private/internal use)
-- 0xfb	HFC RIS MAC
-- 0xfc	HFC DOCSIS MAC
-- 0xfd	HFC HMS MAC
-- 0xfe	HFC Teleste MAC
-- 
		NetworkInterfaceType ::= INTEGER
