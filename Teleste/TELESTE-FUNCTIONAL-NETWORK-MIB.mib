			networkInterfaceTypeHfcHmsMac(253),
			networkInterfaceTypeCatvisorMac(254),
			networkInterfaceTypeNA(255)
			}

-- Network interface/port (software wise) enable/disable control.
-- 
-- 1: Port is enabled/allowed to communicate (software wise). Port may be powered down or up depending cable connections.
-- 2: Port is disabled/disallowed to communicate (software wise).
		NetworkInterfacePortEnable ::= INTEGER
			{
			networkInterfaceEnabled(1),
			networkInterfaceDisabled(2)
			}

	
