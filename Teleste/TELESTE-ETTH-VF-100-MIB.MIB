--			SEQUENCE {  
--				etthENMSetIndex
--					INTEGER,
--				etthENMSetUSPower
--					INTEGER,
--				etthENMSetDSCenterFrequency
--					INTEGER,
--				etthENMSetDSChannelSeparation
--					INTEGER
--			} 
			
--		etthENMSetIndex OBJECT-TYPE
--			SYNTAX INTEGER
--			ACCESS read-only
--			STATUS mandatory
--			DESCRIPTION
--				"The value of this object uniquely identifies this entry."
--			::= { etthENMSettingsEntry 1 } 
			
--		etthENMSetUSPower OBJECT-TYPE
--			SYNTAX INTEGER	
--			ACCESS read-write
--			STATUS mandatory
--			DESCRIPTION
--				"Upstream power level."
  --
--			::= { etthENMSettingsEntry 2 }
			 
--		etthENMSetDSCenterFrequency OBJECT-TYPE
--			SYNTAX INTEGER	
--			UNITS "hertz"
--			ACCESS read-write
--			STATUS mandatory
--			DESCRIPTION
--				"Center frequency of the lower downstream channel."
--			::= { etthENMSettingsEntry 3 } 
			
--		etthENMSetDSChannelSeparation OBJECT-TYPE
--			SYNTAX INTEGER	
--			UNITS "hertz"
--			ACCESS read-write
--			STATUS mandatory
--			DESCRIPTION
--				"The separation between the lower and upper downstream channels."
--			::= { etthENMSettingsEntry 4 }       
         
        
--
-- etthENMUpstreamChannelSettingsTable
--           
		etthENMUpstreamChannelSettingsTable OBJECT-TYPE
			SYNTAX SEQUENCE OF EtthENMUpstreamChannelSettingsEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"This table contains settings entries for ENM upstream channels."
			::= { etthVF100ENMSettingsObjects 2 }

		etthENMUpstreamChannelSettingsEntry OBJECT-TYPE
			SYNTAX EtthENMUpstreamChannelSettingsEntry
			ACCESS not-accessible
			STATUS mandatory 
			DESCRIPTION
				"An entry containing settings for ENM upstream channels."
			INDEX { etthUpChSettingsIndex }
			::= { etthENMUpstreamChannelSettingsTable 1 }
		
		EtthENMUpstreamChannelSettingsEntry ::=
			SEQUENCE { 
				etthUpChSettingsIndex
					INTEGER, 
--				etthUpChSettingsChannel
--					INTEGER, 
				etthUpChSettingsPower
					INTEGER,
				etthUpChSettingsModulation
					INTEGER,
				etthUpChSettingsBurstLength
					INTEGER 
			 }
			 
		etthUpChSettingsIndex OBJECT-TYPE
			SYNTAX INTEGER	
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"The value of this object uniquely identifies this entry."

			::= { etthENMUpstreamChannelSettingsEntry 1 }    
			 
--		etthUpChSettingsChannel OBJECT-TYPE
--			SYNTAX INTEGER	
--			ACCESS read-only
--			STATUS mandatory
--			DESCRIPTION
--				"Index of an upstream channel."
--
--			::= { etthENMUpstreamChannelSettingsEntry 2 } 

		etthUpChSettingsPower OBJECT-TYPE
			SYNTAX TenthDecimal	
			UNITS "dBuV"
			ACCESS read-write
			STATUS mandatory   
			DESCRIPTION
				"Upstream power level. The nominal commanded target level at the connector that the eams will be ranged to. "

			::= { etthENMUpstreamChannelSettingsEntry 2 }
   
			
		etthUpChSettingsModulation OBJECT-TYPE
			SYNTAX INTEGER
				{
				qam4(1),
				--qam8(2),
				qam16(3),
				--qam32(4),
				qam64(5),
				--qam128(6),
				qam256(7)--,
				--other(254),
				--unknown(255)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Upstream modulation."

			::= { etthENMUpstreamChannelSettingsEntry 3 }  
			
		etthUpChSettingsBurstLength OBJECT-TYPE
			SYNTAX INTEGER	
			{
				rs1(1),
				rs2(2),
				rs4(4),
				rs8(8)
			}		     
			UNITS "RS Blocks"
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Upstream burst length."

			::= { etthENMUpstreamChannelSettingsEntry 4 } 
        

 END
