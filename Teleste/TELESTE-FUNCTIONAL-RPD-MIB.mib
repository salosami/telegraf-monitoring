		-- 1.3.6.1.4.1.3715.100.103.4
		rpdLocalManagementPortInformation OBJECT IDENTIFIER ::= { rpd 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.4.1
		rpdLocalPortStatus OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Local management (RJ-45) status
				
				1: link up, 
				2: link down, 
				3: error, 
				4: unknown, 
				5: N/A"
			::= { rpdLocalManagementPortInformation 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.4.2
		rpdLocalPortBitrate OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Local management port (RJ-45) bitrate. Unit 1 Mbps.
				
				0: Bitrate info not available."
			::= { rpdLocalManagementPortInformation 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.4.3
		rpdLocalPortMacAddress OBJECT-TYPE
			SYNTAX TPhysAddress
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Local maangement port (RJ-45) MAC address. 
				If the MAC address is unknown '00.00.00.00.00.00' is returned."
			::= { rpdLocalManagementPortInformation 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.5
		rpdRemotePortInformation OBJECT IDENTIFIER ::= { rpd 5 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.1
		rpdRemotePortCount OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of remote ports in RPD."
			::= { rpdRemotePortInformation 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2
		rpdRemotePortInfomationTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdRemotePortInfomationEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdRemotePortInformation 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1
		rpdRemotePortInfomationEntry OBJECT-TYPE
			SYNTAX RpdRemotePortInfomationEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdRemotePortInfomationIndex }
			::= { rpdRemotePortInfomationTable 1 }

		
		RpdRemotePortInfomationEntry ::=
			SEQUENCE { 
				rpdRemotePortInfomationIndex
					INTEGER,
				rpdRemotePortInformationStatus
					INTEGER,
				rpdRemotePortInfomationBitrate
					INTEGER,
				rpdRemotePortInfomationWaveLength
					INTEGER,
				rpdRemotePortInfomationTemperature
					INTEGER,
				rpdRemotePortInfomationMacAddress
					TPhysAddress
			 }

		-- 1.3.6.1.4.1.3715.100.103.5.2.1.1
		rpdRemotePortInfomationIndex OBJECT-TYPE
			SYNTAX INTEGER (1..3)
			ACCESS read-write
			STATUS mandatory
			::= { rpdRemotePortInfomationEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1.2
		rpdRemotePortInformationStatus OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Remote port (SFP) status.
				
				1: link up, 
				2: link down, 
				3: error, 
				4: unknown, 
				5: N/A, 
				6: no SFP, 
				7: no fiber"
			::= { rpdRemotePortInfomationEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1.3
		rpdRemotePortInfomationBitrate OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Remote port (SFP) bitrate. Unit 1 Mbps.
				
				0: Bitrate info not available."
			::= { rpdRemotePortInfomationEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1.4
		rpdRemotePortInfomationWaveLength OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Remote port (SFP) wavelength. Unit 0.001 nm. 
				
				Example: 
				1310456 means: 1310.456 nm."
			::= { rpdRemotePortInfomationEntry 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1.5
		rpdRemotePortInfomationTemperature OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Remote port (SFP) temperature. Unit 0.01 oC.
				Exact value 0.00 oC (0x0000) indicates that temperature information is not available."
			::= { rpdRemotePortInfomationEntry 5 }

		
		-- 1.3.6.1.4.1.3715.100.103.5.2.1.6
		rpdRemotePortInfomationMacAddress OBJECT-TYPE
			SYNTAX TPhysAddress
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Remote maangement port (SFP) MAC address. 
				If the MAC address is unknown '00.00.00.00.00.00' is returned."
			::= { rpdRemotePortInfomationEntry 6 }

		
		-- 1.3.6.1.4.1.3715.100.103.6
		rpdDsChannels OBJECT IDENTIFIER ::= { rpd 6 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.1
		rpdNumberOfDownStreams OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of down streams (DS). Unit 1 DS."
			::= { rpdDsChannels 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.2
		rpdDsChannelsTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdDsChannelsEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdDsChannels 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.2.1
		rpdDsChannelsEntry OBJECT-TYPE
			SYNTAX RpdDsChannelsEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdDsChannelsTableIndex }
			::= { rpdDsChannelsTable 1 }

		
		RpdDsChannelsEntry ::=
			SEQUENCE { 
				rpdDsChannelsTableIndex
					INTEGER,
				rpdDsChannelsTableData0-399
					OCTET STRING,
				rpdDsChannelsTableData400-799
					OCTET STRING,
				rpdDsChannelsTableData800-1199
					OCTET STRING,
				rpdDsChannelsTableData1200-1599
					OCTET STRING,
				rpdDsChannelsTableData1600-1999
					OCTET STRING,
				rpdDsChannelsNumberOfChannels
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.100.103.6.2.1.1
		rpdDsChannelsTableIndex OBJECT-TYPE
			SYNTAX INTEGER (1..4)
			ACCESS read-write
			STATUS mandatory
			::= { rpdDsChannelsEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.2.1.2
		rpdDsChannelsTableData0-399 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Type: uint8:
				- 0: Type 0 is used to indicate uninitialized channel table data. Stop processing channel entries. No valid data after this for this table/block.
				- 1: This whole channel info is not used; no need to check this table/block further.
				- 2: Unused/fill, skip to next ChannelInfoEntry.
				- 3: N/A
				- 4: Analog
				- 5: AM
				- 6: FM
				- 7: PM
				- 8: ASK
				- 9: FSK
				- 10: PSK
				- 11: OOK
				- 12: CW
				- 13: Pilot
				- 14: RPG pilot
				- 15: Optical transmitter pilot
				- 16: HMS MAC
				- 17: CATVisor MAC
				- 18: RIS MAC
				- 19: PAL
				- 20: SECAM
				- 21: NTSC
				- 22: NDF
				- 23: NDR
				- 24: OOB
				- 25: QPSK
				- 26: AnnexA - modulation order unknown
				- 27: AnnexA - QAM2
				- 28: AnnexA - QAM4
				- 29: AnnexA - QAM8
				- 30: AnnexA - QAM16
				- 31: AnnexA - QAM32
				- 32: AnnexA - QAM64
				- 33: AnnexA - QAM128
				- 34: AnnexA - QAM256
				- 35: AnnexA - QAM512
				- 36: AnnexA - QAM1024
				- 37: AnnexA - QAM2048
				- 38: AnnexA - QAM4096
				- 39: AnnexA - QAM8192
				- 40: AnnexA - QAM16384
				- 41: AnnexA - QAM32768
				- 42: AnnexA - QAM65536
				- 43: AnnexA - QAM131072
				- 44: AnnexB - modulation order unknown
				- 45: AnnexB - QAM2
				- 46: AnnexB - QAM4
				- 47: AnnexB - QAM8
				- 48: AnnexB - QAM16
				- 49: AnnexB - QAM32
				- 50: AnnexB - QAM64
				- 51: AnnexB - QAM128
				- 52: AnnexB - QAM256
				- 53: AnnexB - QAM512
				- 54: AnnexB - QAM1024
				- 55: AnnexB - QAM2048
				- 56: AnnexB - QAM4096
				- 57: AnnexB - QAM8192
				- 58: AnnexB - QAM16384
				- 59: AnnexB - QAM32768
				- 60: AnnexB - QAM65536
				- 61: AnnexB - QAM131072
				- 62: AnnexC - modulation order unknown
				- 63: AnnexC - QAM2
				- 64: AnnexC - QAM4
				- 65: AnnexC - QAM8
				- 66: AnnexC - QAM16
				- 67: AnnexC - QAM32
				- 68: AnnexC - QAM64
				- 69: AnnexC - QAM128
				- 70: AnnexC - QAM256
				- 71: AnnexC - QAM512
				- 72: AnnexC - QAM1024
				- 73: AnnexC - QAM2048
				- 74: AnnexC - QAM4096
				- 75: AnnexC - QAM8192
				- 76: AnnexC - QAM16384
				- 77: AnnexC - QAM32768
				- 78: AnnexC - QAM65536
				- 79: AnnexC - QAM131072
				- 80: OFDM (full channel/contiguous channel)
				- 81: OFDM (start of channel)
				- 82: OFDM (continued channel)
				- 83: OFDM (continued channel and end of channel)
				- 84: OFDMA (full channel/contiguous channel)
				- 85: OFDMA (start of channel)
				- 86: OFDMA (continued channel)
				- 87: OFDMA (continued channel and end of channel)
				- 88: Ingress
				- 89: Noise
				- 90: White noise
				- 91: Test signal
				- 92: Viavi signal
				- 93: Other
				- 94: Other downstream
				- 95: Other upstream
				- 96: Unknown
				- 97: Unknown dowstream
				- 98: Unknown upstream
				- 99: No channels at all. This is used when there's no RF channels, but automatic powersave is in use and there's need to get hybrid bias to minimum.
				Status: uint8: bitwise coded
				- 0x01	Status ok
				- 0x02	No cable modems online
				- 0x04	Cable modem(s) registering
				- 0x08	Cable modem(s) registered, no traffic
				- 0x10	Cable modem(s) registered, traffic/transmitting data
				- 0x20	reserved
				- 0x40	Not used channel (used to fill channel info table)
				- 0x80	EndOfChannels
				Start frequency: uint16	
				- Unit&scale	0,05 MHz
				- Range	0...3276,75 MHz
				Stop frequency: uint16	
				- Unit&scale	0,05 MHz
				- Range	0...3276,75 MHz
				Level: int16	
				- Unit&scale	0,01 dBmV/1 MHz channel
				- Range	-327,68...327,67 dBmV
				Slope: int8	
				- Unit&scale	0,2 dB
				- Range	-25,6...25,4 dB
				SNR: uint8	
				- Unit&scale	0,2 dB
				- Range	0...51,0 dB
				
				
				
				"
			::= { rpdDsChannelsEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.2.1.3
		rpdDsChannelsTableData400-799 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdDsChannelsTableData0-399."
			::= { rpdDsChannelsEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.6.2.1.4
