		-- 1.3.6.1.4.1.3715.100.103.1.3
		rpdSysDescription OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"This object contains textual information about RPD module.
				
				Format: Manufacturer HwModel <<HW_REV: XX.X; VENDOR: Vendor; BOOTR: 1.2.3; SW_REV: 4.5.6; MODEL: HwModel; SERIAL: SK12345678; BOOTCOUNT: #; UPTIME: fulldays# d hh:mm:ss; TOTAL_UPTIME: fulldays#; DOWNSTREAMS: NumberOfDownStreams; UPSTREAMS: NumberOFUpStreams>>
				
				Keywords are UPPER CASE and any of them can be omitted and they can be used in any order.
				
				Example: Teleste RPD123 <<HW_REV: A1.0; VENDOR: Teleste; SW_REV: 1.2; MODEL: RPD123; SERIAL: KL12341737; BOOTCOUNT: 78; UPTIME: 22 d 11:22:33; TOTAL_UPTIME: 47; DOWNSTREAMS: 1; UPSTREAMS: 2>>"
			::= { rpdStatus 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.4
		rpdType OBJECT-TYPE
			SYNTAX INTEGER
				{
				rpdTypeNone(1),
				rpdType1Ds1Us(2),
				rpdType1Ds2Us(3),
				rpdType1Ds4Us(4),
				rpdType2Ds2Us(5),
				rpdType2Ds4Us(6),
				rpdType2Ds1Us(7)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Installed RPD module type.
