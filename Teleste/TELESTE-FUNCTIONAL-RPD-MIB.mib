		-- 1.3.6.1.4.1.3715.100.103.1.9
		rpdTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				temperatureStatusUninitialized(0),
				temperatureStatusNormal(1),
				temperatureStatusHIHI(2),
				temperatureStatusHi(3),
				temperatureStatusLo(4),
				temperatureStatusLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's internal temperature status.
				Limits are not editable or visible.
				
				0: Uninitialized: rpdTemperature value is not relevant.
				1: Normal
				2: HIHI: Temperature is over HIHI limit
				3: Hi: Temperature is over Hi limit
				4: Lo: Tempearture is below Lo limit
				5: LOLO: Temperature is below LOLO limit"
			::= { rpdStatus 9 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.10
		rpdBootUpProcessStatusBits OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status in bit mask. See also rpdBootUpProcessStatusBitsMask.
				When bit is set '1': status is ok.
				When bit is reset '0': status is not ok (nok).
				
				0x0001: Local RPD init
				0x0002: CIN link up
				0x0004: Network authentication (802.1x)
				0x0008: reserved
				0x0010: IP address assignment (DHCP)
				0x0020: IPv4 address
				0x0040: IPv6 address
				0x0080: Get ToD
				0x0100: IPSec
				0x0200: TCP init
				0x0400: GCP INIT IRA
				0x0800: GCP INIT CFG
				0x1000: Connected to principal core
				0x2000: Software update in progress
				0x4000: Configuration complete
				0x8000: Operational"
			::= { rpdStatus 10 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.11
		rpdBootUpProcessStatusBitsMask OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status bits mask in bit mask. See also rpdBootUpProcessStatusBits.
				When mask bit is set '1': bit in rpdBootUpProcessStatusBits should be checked.
				When mask bit is reset '0': bit in rpdBootUpProcessStatusBits should be ignored (or considered ok regardless rpdBootUpProcessStatusBits value)."
			::= { rpdStatus 11 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.12
		rpdSwStatusBits OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status in bit mask. See also rpdBootUpProcessStatusBitsMask.
				When bit is set '1': status is ok.
				When bit is reset '0': status is not ok (nok).
				
				0x0001: PTP unqaulified
				0x0002: PTP lock acquisition
				0x0004: PTP frequency locked
				0x0008: PTP time locked
				0x0010: PTP holdover in spec
				0x0020: PTP holdover out of spec
				0x0040: reserved
				0x0080: reserved
				0x0100: Reboot in progress
				0x0200: GCP keepalive
				0x0400: reserved
				0x0800: reserved
				0x1000: Auxilliary cores
				0x2000: L2TP sessions
				0x4000: reserved
				0x8000: reserved"
			::= { rpdStatus 12 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.13
		rpdSwStatusBitsMask OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status bits mask in bit mask. See also rpdSwStatusBits.
				When mask bit is set '1': bit in rpdSwStatusBits should be checked.
				When mask bit is reset '0': bit in rpdSwStatusBits should be ignored (or considered ok regardless rpdSwStatusBits value)."
			::= { rpdStatus 13 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.14
		rpdHwStatusBits OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status in bit mask. See also rpdBootUpProcessStatusBitsMask.
				When bit is set '1': status is ok.
				When bit is reset '0': status is not ok (nok).
				
				0x0001: Voltages
				0x0002: HeartBeat (between RPD and cortex)
				0x0004…0x8000: reserved"
			::= { rpdStatus 14 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.15
		rpdHwStatusBitsMask OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RPD's boot-up process status bits mask in bit mask. See also rpdHwStatusBits.
				When mask bit is set '1': bit in rpdHwStatusBits should be checked.
				When mask bit is reset '0': bit in rpdHwStatusBits should be ignored (or considered ok regardless rpdHwStatusBits value)."
			::= { rpdStatus 15 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.16
		rpdDsUsInfo OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's current DS and US status and capabilities.
				
				Downstream (DS)
				0x0001: When bit is 1: DS1 active/enabled, when bit is 0: DS1 not in use/disabled
				0x0002: When bit is 1: DS2 active/enabled, when bit is 0: DS2 not in use/disabled
				0x0004: When bit is 1: DS3 active/enabled, when bit is 0: DS3 not in use/disabled
				0x0008: When bit is 1: DS4 active/enabled, when bit is 0: DS4 not in use/disabled
				0x0010: When bit is 1: DS1 exists (can be enabled), when bit is 0: DS1 doesn't exists (can't be enabled)
				0x0020: When bit is 1: DS2 exists (can be enabled), when bit is 0: DS2 doesn't exists (can't be enabled)
				0x0040: When bit is 1: DS3 exists (can be enabled), when bit is 0: DS3 doesn't exists (can't be enabled)
				0x0080: When bit is 1: DS4 exists (can be enabled), when bit is 0: DS4 doesn't exists (can't be enabled)
				
				Upstream (US)
				0x0100: When bit is 1: DS1 active/enabled, when bit is 0: DS1 not in use/disabled
				0x0200: When bit is 1: DS2 active/enabled, when bit is 0: DS2 not in use/disabled
				0x0400: When bit is 1: DS3 active/enabled, when bit is 0: DS3 not in use/disabled
				0x0800: When bit is 1: DS4 active/enabled, when bit is 0: DS4 not in use/disabled
				0x1000: When bit is 1: DS1 exists (can be enabled), when bit is 0: DS1 doesn't exists (can't be enabled)
				0x2000: When bit is 1: DS2 exists (can be enabled), when bit is 0: DS2 doesn't exists (can't be enabled)
				0x4000: When bit is 1: DS3 exists (can be enabled), when bit is 0: DS3 doesn't exists (can't be enabled)
				0x8000: When bit is 1: DS4 exists (can be enabled), when bit is 0: DS4 doesn't exists (can't be enabled)"
			::= { rpdStatus 16 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.17
		rpdCurrentTime OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's current time in posix format. Unit 1 s. Epoch 1.1.1970."
			::= { rpdStatus 17 }
-- RPD's current time in posix format. Unit 1 s. Epoch 1.1.1970.
		
		-- 1.3.6.1.4.1.3715.100.103.1.18
		rpdLastResponse OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of seconds since last packet received from RPD by node. Unit 1 s.
				Node provides this information. 
				
				0: no packet received from RPD by node (yet), 
				1-65534: number of seconds since last received packet, 
				65535: communication problem."
			::= { rpdStatus 18 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.19
		rpdDelayUntilNextReboot OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD informs when RPD reboots next time. Unit 1 s.
				See also rpdAutomaticReconnectRebootTimeout.
				
				0: Unknown (typically: node has not yet received information from RPD), 
				1-65534: number of seconds until next RPD reboot, 
				65535: No reboot scheduled."
			::= { rpdStatus 19 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.20
		rpdAutomaticReconnectRebootTimeout OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD informs the length of the time period that RPD tries to get online.
				See also  rpdDelayUntilNextReboot.
				
				0: Unknown (typically: node has not yet received information from RPD), 
				1-65534: number of seconds RPD tries to get online until RPD makes reboot, 
				65535: automatic reboot disabled. See also rpdDelayUntilNextReboot."
			::= { rpdStatus 20 }

		
		-- 1.3.6.1.4.1.3715.100.103.1.21
		rpdUptimeDays OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RPD's uptime in full days. Unit 1 day."
