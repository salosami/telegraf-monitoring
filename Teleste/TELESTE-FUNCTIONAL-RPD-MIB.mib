		-- 1.3.6.1.4.1.3715.100.103.6.2.1.7
		rpdDsChannelsNumberOfChannels OBJECT-TYPE
			SYNTAX INTEGER (0..200)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of channels in rpdDsChannelsTableData."
			::= { rpdDsChannelsEntry 7 }

		
		-- 1.3.6.1.4.1.3715.100.103.7
		rpdUsChannels OBJECT IDENTIFIER ::= { rpd 7 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.1
		rpdNumberOfUpStreams OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of up streams (US). Unit 1 US."
			::= { rpdUsChannels 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2
		rpdUsChannelsTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdUsChannelsEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdUsChannels 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1
		rpdUsChannelsEntry OBJECT-TYPE
			SYNTAX RpdUsChannelsEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdUsChannelsTableIndex }
			::= { rpdUsChannelsTable 1 }

		
		RpdUsChannelsEntry ::=
			SEQUENCE { 
				rpdUsChannelsTableIndex
					INTEGER,
				rpdUsChannelsTableData0-399
					OCTET STRING,
				rpdUsChannelsTableData400-799
					OCTET STRING,
				rpdUsChannelsTableData800-1199
					OCTET STRING,
				rpdUsChannelsTableData1200-1599
					OCTET STRING,
				rpdUsChannelsTableData1600-1999
					OCTET STRING,
				rpdUsChannelsNumberOfChannels
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.100.103.7.2.1.1
		rpdUsChannelsTableIndex OBJECT-TYPE
			SYNTAX INTEGER (1..4)
			ACCESS read-write
			STATUS mandatory
			::= { rpdUsChannelsEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.2
		rpdUsChannelsTableData0-399 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdDsChannelsTableData0-399."
			::= { rpdUsChannelsEntry 2 }
-- 
-- 
-- 
-- 
		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.3
		rpdUsChannelsTableData400-799 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdDsChannelsTableData0-399."
			::= { rpdUsChannelsEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.4
		rpdUsChannelsTableData800-1199 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdDsChannelsTableData0-399."
			::= { rpdUsChannelsEntry 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.5
		rpdUsChannelsTableData1200-1599 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdDsChannelsTableData0-399."
			::= { rpdUsChannelsEntry 5 }

		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.6
		rpdUsChannelsTableData1600-1999 OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bytecoded data.
				
				Description: See rpdUsChannelsTableData0-399."
			::= { rpdUsChannelsEntry 6 }
-- 
-- 
		
		-- 1.3.6.1.4.1.3715.100.103.7.2.1.7
		rpdUsChannelsNumberOfChannels OBJECT-TYPE
			SYNTAX INTEGER (0..200)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of channels in rpdUsChannelsTableData."
			::= { rpdUsChannelsEntry 7 }

		
		-- 1.3.6.1.4.1.3715.100.103.8
		rpdStatusLog OBJECT IDENTIFIER ::= { rpd 8 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.1
		rpdStatusLogRowCount OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of rows in status log."
			::= { rpdStatusLog 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.2
		rpdStatusLogLastIndex OBJECT-TYPE
			SYNTAX INTEGER (1..65535)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Last log index."
			::= { rpdStatusLog 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.3
		rpdStatusLogTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdStatusLogEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdStatusLog 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.3.1
		rpdStatusLogEntry OBJECT-TYPE
			SYNTAX RpdStatusLogEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdStatusLogStorageSlot }
			::= { rpdStatusLogTable 1 }

		
		RpdStatusLogEntry ::=
			SEQUENCE { 
				rpdStatusLogStorageSlot
					INTEGER,
				rpdStatusLogIndex
					INTEGER,
				rpdStatusLogTimeStamp
					OCTET STRING,
				rpdStatusLogText
					OCTET STRING
			 }

		-- 1.3.6.1.4.1.3715.100.103.8.3.1.1
		rpdStatusLogStorageSlot OBJECT-TYPE
			SYNTAX INTEGER (1..65535)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Status log event storage slot.
				Device has limited (and fixed number of) storage slots. Events are returned on storage slot order. To get correct chronological order, 
				sort entries using rpdStatusLogIndex (taking care of index wrap around)."
			::= { rpdStatusLogEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.3.1.2
		rpdStatusLogIndex OBJECT-TYPE
			SYNTAX INTEGER (1..65535)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Index of log entry. Wraps around.
				Log entries are returned in storage slot order.
				This field indicates chronological order.
				
				If rpdStatusLogIndex value is 0, then this storage slot is uninitialized and does not contain any relevant information."
			::= { rpdStatusLogEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.3.1.3
		rpdStatusLogTimeStamp OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Timestamp of event.
				
				If rpdStatusLogTimeStamp value is 0, then this storage slot is uninitialized and does not contain any relevant information."
			::= { rpdStatusLogEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.8.3.1.4
		rpdStatusLogText OBJECT-TYPE
			SYNTAX OCTET STRING (SIZE (0..50))
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Textual description of event. Field maximum size uint8[50]."
			::= { rpdStatusLogEntry 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.9
		rpdNodeInfo OBJECT IDENTIFIER ::= { rpd 9 }

		
		-- 1.3.6.1.4.1.3715.100.103.9.1
		rpdNodeOutputPower1 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 1 power calculated from appropriate DS channel table (based on routing) and gain&slope settings by node.
				If no channel info available, value 9999 is returned. 
				If output is not in use -9999 is returned.
				
				Unit 0.01 dBm"
			::= { rpdNodeInfo 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.9.2
		rpdNodeOutputPower2 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 2 power calculated from appropriate DS channel table (based on routing) and gain&slope settings by node.
				If no channel info available, value 9999 is returned. 
				If output is not in use -9999 is returned.
				
				Unit 0.01 dBm"
			::= { rpdNodeInfo 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.9.3
		rpdNodeOutputPower3 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 3 power calculated from appropriate DS channel table (based on routing) and gain&slope settings by node.
				If no channel info available, value 9999 is returned. 
				If output is not in use -9999 is returned.
				
				Unit 0.01 dBm"
			::= { rpdNodeInfo 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.9.4
		rpdNodeOutputPower4 OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Output 1 power calculated from appropriate DS channel table (based on routing) and gain&slope settings by node.
				If no channel info available, value 9999 is returned. 
				If output is not in use -9999 is returned.
				
				Unit 0.01 dBm"
			::= { rpdNodeInfo 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.10
		rpdUps OBJECT IDENTIFIER ::= { rpd 10 }

		
		-- 1.3.6.1.4.1.3715.100.103.10.1
		upsStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				upsStatusOk(1),
				upsStatusActive(2),
				upsStatusFailure(3),
				upsStatusNA(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"UPS status.
				1: Normal operation, everything ok.
				2: UPS activated.
				3: UPS failure. Internal error in UPS.
				4: UPS not available."
			::= { rpdUps 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.10.2
		upsCounterReset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"UPS reset requests. Bitfield
				- 0x0001: Request UPS to do SwReset
				- 0x0010: Request UPS to clear log
				- 0x0020: Request UPS to clear activation/failed/successful counter
				- 0x0080: Request UPS to clear charging started/charging interrupted/charging finished counter
				
				Read returns always 0."
			::= { rpdUps 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.10.3
		upsIdData OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"UPS Identification data (32 bytes). Unused chars are set to 0x00 (so C string, not pascal string)
				'- Serial number: char [10]; e.g. SK20201208
				'- Type/Model: char[15]; e.g. UPS123
				'- HwVersion: char[4]; e.g. A1.0
				'- Driver: uint8_t; e.g. 0xFD
				'- Fletcher checkum: uint16_t"
			::= { rpdUps 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.10.4
		upsStatusData OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"UPS status
				- Current posix time: uint32_t [1 s]
				- Current uptime (full days): uint32_t [1 d]
				- Current uptime (seconds in this day): uint32_t [1 s]
				- Total uptime (full days): uint32_t [1 d]
				- Reset count: uint32_t [1 reset]
				- Maximum Event log entry count (MaximumEventLogEntryCount): uint32_t [1]
				- Application version (vMAJOR.MINOR.BUILD): uint32_t: 0xMAMIBUIL, where MA: major (uint8_t), MI: minor (uint8_t), BUIL: build (uint16_t)
				- Application build date: uint32_t: 0xDDMMYYYY, where DD: Application build day (uint8_t; 1-31), MM: Application build month (uint8_t; 1-12), YYYY: Application build year (uint16_t; 0-65535)
				- Current temperature: int32_t [0.01 oC]; if temperature not available, return -99999.
				- Last UPS activation time (posix time stamp): uint32_t [1 s]; if UPS has not been active: 0.
				- Seconds since last UPS activation: uint32_t [1 s]; if UPS has not been active: 0.
				- UPS activation count: uint32_t [1 activation]; end user can reset this.
				- UPS total activation count: uint32_t [1]; this this not end-user resetable.
				- UPS failed count: uint32_t [1]; end user can reset this.
				- UPS total failed count: uint32_t [1]; this this not end-user resetable.
				- UPS successful count: uint32_t [1 activation]; end user can reset this.
				- UPS total successful count: uint32_t [1 activation]; this this not end-user resetable.
				- UPS charging started count: uint32_t [1 activation]; end user can reset this.
				- UPS total charging started count: uint32_t [1 activation]; this this not end-user resetable.
				- UPS charging finished count: uint32_t [1 activation]; end user can reset this.
				- UPS total charging finished count: uint32_t [1 activation]; this this not end-user resetable.
				- UPS charging interrupted count: uint32_t [1 activation]; end user can reset this.
				- UPS total charging interrupted count: uint32_t [1 activation]; this this not end-user resetable."
			::= { rpdUps 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.10.5
		upsTemperatureHistogram OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Temperature histogram data.
				- uint16 Number of temperature measurements < 5 oC
				- uint16 Number of temperature measurements 5…15 oC
				- uint16 Number of temperature measurements 15…25 oC
				- uint16 Number of temperature measurements 25…35 oC
				- uint16 Number of temperature measurements 35…45 oC
				- uint16 Number of temperature measurements 45…55 oC
				- uint16 Number of temperature measurements 55…65 oC
				- uint16 Number of temperature measurements 65…75 oC
				- uint16 Number of temperature measurements 75…85 oC
				- uint16 Number of temperature measurements > 85 oC
				"
			::= { rpdUps 5 }

		
		-- 1.3.6.1.4.1.3715.100.103.11
		rpdUpsEventLog OBJECT IDENTIFIER ::= { rpd 11 }

		
		-- 1.3.6.1.4.1.3715.100.103.11.1
		rpdUpsEventLogRowCount OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of rows in UPS event log."
			::= { rpdUpsEventLog 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.11.2
		rpdUpsEventLogTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdUpsEventLogEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdUpsEventLog 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.11.2.1
		rpdUpsEventLogEntry OBJECT-TYPE
			SYNTAX RpdUpsEventLogEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdUpsEventLogStorageSlot }
			::= { rpdUpsEventLogTable 1 }

		
		RpdUpsEventLogEntry ::=
			SEQUENCE { 
				rpdUpsEventLogStorageSlot
					INTEGER,
				rpdUpsEventLogData
					OCTET STRING
			 }

		-- 1.3.6.1.4.1.3715.100.103.11.2.1.1
		rpdUpsEventLogStorageSlot OBJECT-TYPE
			SYNTAX INTEGER (1..1000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"UPS event log storage slot.
				Device has limited (and fixed number of) storage slots. Events are returned on storage slot order. To get correct chronological order, 
				sort entries using rpdUpsEventLogData.EventIndex (taking care of index wrap around)."
			::= { rpdUpsEventLogEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.11.2.1.2
		rpdUpsEventLogData OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"UPS event log entry
				- Index of event (IndexOfEvent): uint32_t (range: 1...2^32-1)
				- EventTime (= posix timestamp): uint32_t
				- Reset count @ event time: uint32_t
				- EventType: uint32_t
				- EventInfo: uint32_t"
			::= { rpdUpsEventLogEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.12
		rpdShelfPsu OBJECT IDENTIFIER ::= { rpd 12 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.1
		rpdShelfPsuNumberOfPsus OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of PSUs."
			::= { rpdShelfPsu 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2
		rpdShelfPsuTable OBJECT-TYPE
			SYNTAX SEQUENCE OF RpdShelfPsuEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { rpdShelfPsu 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1
		rpdShelfPsuEntry OBJECT-TYPE
			SYNTAX RpdShelfPsuEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { rpdShelfPsuIndex }
			::= { rpdShelfPsuTable 1 }

		
		RpdShelfPsuEntry ::=
			SEQUENCE { 
				rpdShelfPsuIndex
					INTEGER,
				rpdShelfPsuHwModel
					OCTET STRING,
				rpdShelfPsuSerialNumber
					OCTET STRING,
				rpdShelfPsuHwVersion
					OCTET STRING,
				rpdShelfPsuSwVersion
					OCTET STRING,
				rpdShelfPsuInstallationPosition
					INTEGER,
				rpdShelfPsuUptime
					OCTET STRING,
				rpdShelfPsuTotalUptime
					INTEGER,
				rpdShelfPsuResetCount
					INTEGER,
				rpdShelfPsu24Voltage
					INTEGER,
				rpdShelfPsuCurrent
					INTEGER,
				rpdShelfPsuTemperature
					INTEGER,
				rpdShelfPsuFan1rpm
					INTEGER,
				rpdShelfPsuFan2rpm
					INTEGER,
				rpdShelfPsuFan1Status
					INTEGER,
				rpdShelfPsuFan2Status
					INTEGER,
				rpdShelfPsuFailureBits
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.100.103.12.2.1.1
		rpdShelfPsuIndex OBJECT-TYPE
			SYNTAX INTEGER (1..10)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Index of PSU."
			::= { rpdShelfPsuEntry 1 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.2
		rpdShelfPsuHwModel OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Hardware model of PSU.
				If hardware model is undefined, then zero length string is returned."
			::= { rpdShelfPsuEntry 2 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.3
		rpdShelfPsuSerialNumber OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Serial number of PSU.
				If serial number is undefined, then zero length string is returned."
			::= { rpdShelfPsuEntry 3 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.4
		rpdShelfPsuHwVersion OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Hardware version of PSU.
				If hardware version is undefined, then zero length string is returned."
			::= { rpdShelfPsuEntry 4 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.5
		rpdShelfPsuSwVersion OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Software version information.
				This might contain only application version number, but is not limited to that. It might contain information about BIOS and dates.
				If software version is undefined, then zero length string is returned."
			::= { rpdShelfPsuEntry 5 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.6
		rpdShelfPsuInstallationPosition OBJECT-TYPE
			SYNTAX INTEGER
				{
				rpdShelfPsuInstallationPositionNA(1),
				rpdShelfPsuInstallationPositionUnknown(2),
				rpdShelfPsuInstallationPositionA(3),
				rpdShelfPsuInstallationPositionB(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU installation position in rack.
				1: N/A
				2: Unknown
				3: A (left)
				4: B (right)
				"
			::= { rpdShelfPsuEntry 6 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.7
		rpdShelfPsuUptime OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Current uptime of PSU."
			::= { rpdShelfPsuEntry 7 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.8
		rpdShelfPsuTotalUptime OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Total uptime the PSU (software) has been running.
				Unit 1 day."
			::= { rpdShelfPsuEntry 8 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.9
		rpdShelfPsuResetCount OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Total number of software resets during PSU's life time.
				Unit 1 reset."
			::= { rpdShelfPsuEntry 9 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.10
		rpdShelfPsu24Voltage OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"+24 Vdc voltage measured by PSU.
				Unit 0.01 V."
			::= { rpdShelfPsuEntry 10 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.11
		rpdShelfPsuCurrent OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Current measured by PSU.
				Unit 0.01 A."
			::= { rpdShelfPsuEntry 11 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.12
		rpdShelfPsuTemperature OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Temperature measured by PSU.
				Unit 0.01 oC."
			::= { rpdShelfPsuEntry 12 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.13
		rpdShelfPsuFan1rpm OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU's fan 1 rpm's measured by PSU.
				Unit 1 rpm."
			::= { rpdShelfPsuEntry 13 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.14
		rpdShelfPsuFan2rpm OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU's fan 2 rpm's measured by PSU.
				Unit 1 rpm."
			::= { rpdShelfPsuEntry 14 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.15
		rpdShelfPsuFan1Status OBJECT-TYPE
			SYNTAX INTEGER
				{
				rpdShelfPsuFan1StatusOk(1),
				rpdShelfPsuFan1StatusFailure(2),
				rpdShelfPsuFan1StatusNA(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU's fan 1 status.
				1: Fan ok
				2: Fan failure
				3: No fan"
			::= { rpdShelfPsuEntry 15 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.16
		rpdShelfPsuFan2Status OBJECT-TYPE
			SYNTAX INTEGER
				{
				rpdShelfPsuFan2StatusOk(1),
				rpdShelfPsuFan2StatusFailure(2),
				rpdShelfPsuFan2StatusNA(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU's fan 2 status.
				1: Fan ok
				2: Fan failure
				3: No fan"
			::= { rpdShelfPsuEntry 16 }

		
		-- 1.3.6.1.4.1.3715.100.103.12.2.1.17
		rpdShelfPsuFailureBits OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"PSU failure bits. If bit is set '1', then failure is active.
				
				0x0001: PSU lost/PSU not detected anymore.
				0x0002: Data communication lost to this PSU.
				0x0004: Data communication lost to other PSU.
				0x0008: PSU +24 V failed.
				0x0010: PSU internal temperature too high.
				0x0020...0x8000: Reserved for future needs."
			::= { rpdShelfPsuEntry 17 }

		
	
	END

--
-- TELESTE-FUNCTIONAL-RPD-MIB.mib
--
