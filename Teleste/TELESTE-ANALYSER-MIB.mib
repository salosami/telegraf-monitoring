		-- 1.3.6.1.4.1.3715.100.2.1
		spectrumAnalyserCount OBJECT-TYPE
			SYNTAX INTEGER (0..8)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of spectrum analysers in this device. Zero value means
				that no analysers are available."
			::= { spectrumAnalyser 1 }

		
		-- 1.3.6.1.4.1.3715.100.2.10
		spectrumAnalyserTable OBJECT-TYPE
			SYNTAX SEQUENCE OF SpectrumAnalyserEntry
			ACCESS not-accessible
			STATUS mandatory
			::= { spectrumAnalyser 10 }

		
