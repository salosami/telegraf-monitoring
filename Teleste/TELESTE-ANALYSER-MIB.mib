		spectrumAnalyserEntry OBJECT-TYPE
			SYNTAX SpectrumAnalyserEntry
			ACCESS not-accessible
			STATUS mandatory
			INDEX { spectrumAnalyserIndex }
			::= { spectrumAnalyserTable 1 }

		
		SpectrumAnalyserEntry ::=
			SEQUENCE { 
				spectrumAnalyserIndex
					INTEGER,
				spectrumAnalyserType
