		cmCertUpdateServer OBJECT-TYPE
			SYNTAX OCTET STRING (SIZE (0..15))
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The IPv4 address of the TFTP server used for CM certificates upgrade.
				If the value for this OID is NULL, then the config file TFTP server address is used."
			::= { cmCertificateUpdate 3 }

		
		-- 1.3.6.1.4.1.8595.1.400.8.4
		cmCertUpdateTrigger OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"When set it to true, triggers the certificate update feature."
			::= { cmCertificateUpdate 4 }

		
		-- 1.3.6.1.4.1.8595.1.400.8.5
		cmCertUpdateVersion OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
