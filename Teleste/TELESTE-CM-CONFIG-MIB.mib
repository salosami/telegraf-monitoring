				"Record containing static cable modem data:
				cmPhysAddress (octet string [6])
				cmSwVersion (string; len (1 octet) + swversion (len octets), len max 15)
				cmHwVersion (string; len (1 octet) + hwversion (len octets), len max 15)
				cmSerialNumber (string; len (1 octet) + serialnumber (len octets), len max 15)"
			::= { cmConfig 3 }

		
		-- 1.3.6.1.4.1.3715.100.999.4
		cmWatchdogTimeout OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"CM watchdog timeout. If docsIfCmStatusValue in cmDynamicParameterRecord 
				is not 'operational(12)' within timeout minutes, CM is reinitialised.
				Unit 1 minute. Value 0 disables CM watchdog."
			::= { cmConfig 4 }

		
		-- 1.3.6.1.4.1.3715.100.999.5
		cmAmpMRU OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Maximum packet size that amplifier can receive from cable modem.
				 
				This value contais payload and headers.
				
				E.g. Legacy HMS: SNMP payload (UDP datagram) (484 bytes), UDP header (8 bytes), IPv4 header (20 bytes): 512 bytes.
				
				If amplifier doesn't support this OID, then default (and legacy) MRU is used: 512 bytes.
				"
			::= { cmConfig 5 }

		
		-- 1.3.6.1.4.1.3715.100.999.6
		cmAmpMTU OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Maximum packet size that amplifier can transmit to cable modem.
				 
				This value contais payload and headers.
				
				E.g. Legacy HMS: SNMP payload (UDP datagram) (484 bytes), UDP header (8 bytes), IPv4 header (20 bytes): 512 bytes.
				
				If amplifier doesn't support this OID, then default (and legacy) MTU is used: 512 bytes."
			::= { cmConfig 6 }

		
		-- 1.3.6.1.4.1.3715.100.999.7
		cmIPv6address OBJECT-TYPE
			SYNTAX OCTET STRING
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
