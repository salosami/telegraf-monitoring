			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Peltier current relative to a max. value (0...100%).
				Unit 0.01 %."
			::= { oVTxEntry 17 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.18
		oVTxTecCurrentRelHiHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Peltier current HIGH alarm limit. Unit 0.01 %."
			::= { oVTxEntry 18 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.19
		oVTxTecCurrentRelHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Peltier current HIGH warning limit. Unit 0.01 %."
			::= { oVTxEntry 19 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.20
		oVTxTecCurrentRelDeadband OBJECT-TYPE
			SYNTAX INTEGER (100..5000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Peltier current deadband value. Unit 0.01 %."
			::= { oVTxEntry 20 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.21
		oVTxLaserTemperature OBJECT-TYPE
			SYNTAX INTEGER
