		-- 1.3.6.1.4.1.3715.3.4.28
		oRRxTable OBJECT-TYPE
			SYNTAX SEQUENCE OF ORRxEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"oRxTable contains element specific information
				for Optical Receiver (BOR26X) modules inserted
				into the BK backplane. 
				"
			::= { bkModules2 28 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1
		oRRxEntry OBJECT-TYPE
			SYNTAX ORRxEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"Row in Table. Note that index is moduleIndex which is column in 
				the moduleTable defined in TELESTE-COMMON-MIB. Rows in this table
				exist only if there are corresponding rows in the moduleTable."
			INDEX { moduleId }
			::= { oRRxTable 1 }

		
		ORRxEntry ::=
			SEQUENCE { 
				oRRx1InputPower
					INTEGER,
				oRRx1InputPowerHiHi
					INTEGER,
				oRRx1InputPowerHi
					INTEGER,
				oRRx1InputPowerLo
					INTEGER,
				oRRx1InputPowerLoLo
					INTEGER,
				oRRx1InputPowerDeadband
					INTEGER,
				oRRx1CodeMainReserve
					INTEGER,
				oRRx1CodeNumberRcvd
					INTEGER,
				oRRx1CodeNumberExptd
					INTEGER,
				oRRx1Mode
					INTEGER,
				oRRx1IngressSwitch
					INTEGER,
				oRRx1OutputLevel
					INTEGER,
				oRRx2InputPower
					INTEGER,
				oRRx2InputPowerHiHi
					INTEGER,
				oRRx2InputPowerHi
					INTEGER,
				oRRx2InputPowerLo
					INTEGER,
				oRRx2InputPowerLoLo
					INTEGER,
				oRRx2InputPowerDeadband
					INTEGER,
				oRRx2CodeMainReserve
					INTEGER,
				oRRx2CodeNumberRcvd
					INTEGER,
				oRRx2CodeNumberExptd
					INTEGER,
				oRRx2Mode
					INTEGER,
				oRRx2IngresSwitch
					INTEGER,
				oRRx2OutputLevel
					INTEGER,
				oRRxCmnMainReserve
					INTEGER,
				oRRxCmnCodeUsage
					INTEGER,
				oRRxCmnOutputMode
					INTEGER,
				oRRxCmnRedundancyMode
					INTEGER,
				oRRx1Status
					INTEGER,
				oRRx1InputPowerStatus
					INTEGER,
				oRRx1PilotStatus
					INTEGER,
				oRRx1CodeStatus
					INTEGER,
				oRRx2Status
					INTEGER,
				oRRx2InputPowerStatus
					INTEGER,
				oRRx2PilotStatus
					INTEGER,
				oRRx2CodeStatus
					INTEGER,
				oRRxCmnLinkStatus
					INTEGER,
				oRRxCmnIngressSwitchStatus
					INTEGER,
				oRRxCmnNominalPortControl
					INTEGER,
				oRRxCmnNotchControl
					INTEGER,
				oRRx1Gain
					INTEGER,
				oRRx1AlcMode
					INTEGER,
				oRRx1AlcStatus
					INTEGER,
				oRRx2Gain
					INTEGER,
				oRRxCmnSlope
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.4.28.1.1
		oRRx1InputPower OBJECT-TYPE
			SYNTAX INTEGER (-1700..300)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical input power (Range: -17.0...+3.0 dBm).
				Unit 0.01 dBm."
			::= { oRRxEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.2
		oRRx1InputPowerHiHi OBJECT-TYPE
			SYNTAX INTEGER (-1700..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power HIGH alarm limit. Unit 0.01 dBm."
			::= { oRRxEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.3
		oRRx1InputPowerHi OBJECT-TYPE
			SYNTAX INTEGER (-1700..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power HIGH warning limit. Unit 0.01 dBm."
			::= { oRRxEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.4
		oRRx1InputPowerLo OBJECT-TYPE
			SYNTAX INTEGER (-1700..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power LOW warning limit. Unit 0.01 dBm."
			::= { oRRxEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.5
		oRRx1InputPowerLoLo OBJECT-TYPE
			SYNTAX INTEGER (-1700..300)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power LOW alarm limit. Unit 0.01 dBm."
			::= { oRRxEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.6
		oRRx1InputPowerDeadband OBJECT-TYPE
			SYNTAX INTEGER (50..500)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power deadband value. Unit 0.01 dBm."
			::= { oRRxEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.7
		oRRx1CodeMainReserve OBJECT-TYPE
			SYNTAX INTEGER
				{
				codeMain(1),
				codeReserve(2),
				codeUnknown(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Received main/reserve code:
				1 = Main
				2 = Reserve
				3 = Unknown"
			::= { oRRxEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.8
		oRRx1CodeNumberRcvd OBJECT-TYPE
			SYNTAX INTEGER (0..999)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Received fiber node number code
				0 = Unknown
				1.. 999 Received number"
			::= { oRRxEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.9
		oRRx1CodeNumberExptd OBJECT-TYPE
			SYNTAX INTEGER (0..999)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Expected transmitter number code (1..999)."
			::= { oRRxEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.10
		oRRx1Mode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeNormal(1),
				modeSleep(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 mode:
				1 = Normal mode
				2 = Sleep mode (no alarms, no warnings)"
			::= { oRRxEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.11
		oRRx1IngressSwitch OBJECT-TYPE
			SYNTAX INTEGER
				{
				att0dB(1),
				att6dB(2),
				att60dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 ingress attenuator state:
				1 = 0 dB
				2 = - 6 dB
				3 = - 60dB (receiver sleep)"
			::= { oRRxEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.12
