			SYNTAX INTEGER
				{
				modeNormal(1),
				modeSleep(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 mode:
				1 = Normal mode
				2 = Sleep mode (no alarms, no warnings)"
			::= { oRRxEntry 22 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.23
		oRRx2IngresSwitch OBJECT-TYPE
			SYNTAX INTEGER
				{
				att0dB(1),
				att6dB(2),
				att60dB(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 ingress attenuator state:
				1 = 0 dB
				2 = - 6 dB
				3 = - 60dB (receiver sleep)"
			::= { oRRxEntry 23 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.24
		oRRx2OutputLevel OBJECT-TYPE
			SYNTAX INTEGER
				{
				level86dBuV(1),
				level80dBuV(2)
				}
			ACCESS read-write
			STATUS mandatory
