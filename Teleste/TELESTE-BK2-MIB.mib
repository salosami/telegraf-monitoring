		oVTxRfAttenuation OBJECT-TYPE
			SYNTAX INTEGER (-400..200)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Input RF attenuation. Unit 0.01 dB."
			::= { oVTxEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.12
		oVTxOmi OBJECT-TYPE
			SYNTAX INTEGER (300..360)
			ACCESS read-write
			STATUS mandatory
