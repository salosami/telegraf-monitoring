				"Receiver 2 output level setting:
				1 = Output level 86 dBµV
				2 = Output level 80 dBµV"
			::= { oRRxEntry 24 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.25
		oRRxCmnMainReserve OBJECT-TYPE
			SYNTAX INTEGER
				{
				codeReserve(1),
				codeMain(2),
				codeUnknown(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Main-reserve setting:
				1 = Reserve (default inactive) mode
				2 = Main (default active) mode
				3 = Unknown (This value is alway ReadOnly)"
			::= { oRRxEntry 25 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.26
		oRRxCmnCodeUsage OBJECT-TYPE
			SYNTAX INTEGER
				{
				lineCodesNotUsed(1),
				lineCodesUsed(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Use of lines codes (both receivers):
				1 = No line codes, hard cofing of main/reserve mode,
				    no code alarms
				2 = Use line codes for main/reserve and transmitter
				    number detection"
			::= { oRRxEntry 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.27
		oRRxCmnOutputMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				outputCommon(1),
				outputSeparate(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Output usage:
				1 = Use common output
				2 = Use separate outputs"
			::= { oRRxEntry 27 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.28
		oRRxCmnRedundancyMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				redundancyNone(1),
				redundancyDevice(2),
				redundancyRoute(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Redundancy mode:
				1 = No redundancy
				2 = Device redundancy
				3 = Channel redundancy"
			::= { oRRxEntry 28 }

		
