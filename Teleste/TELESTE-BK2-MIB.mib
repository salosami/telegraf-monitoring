		-- 1.3.6.1.4.1.3715.3.4.31
		kplTable OBJECT-TYPE
			SYNTAX SEQUENCE OF KplEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"This table contains element specific information
				for Koppler (BKK421) modules inserted into
				the BK backplane."
			::= { bkModules2 31 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1
		kplEntry OBJECT-TYPE
			SYNTAX KplEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"Row in Table. Note that index is moduleIndex which is column in 
				the moduleTable defined in TELESTE-COMMON-MIB. Rows in this table
				exist only if there are corresponding rows in the moduleTable."
			INDEX { moduleId }
			::= { kplTable 1 }

		
		KplEntry ::=
			SEQUENCE { 
				kplGain
					INTEGER,
				kplSlope
					INTEGER,
				kplDetOffset
					INTEGER,
				kplDetRefMode
					INTEGER,
				kplDetRefValue
					INTEGER,
				kplDetOffsetHiHi
					INTEGER,
				kplDetOffsetHi
					INTEGER,
				kplDetOffsetLo
					INTEGER,
				kplDetOffsetLoLo
					INTEGER,
				kplDetOffsetDeadband
					INTEGER,
				kplDetAverageMode
					INTEGER,
				kplRfLevelStatus
					INTEGER,
				kplTemperatureStatus
					INTEGER,
				kplGainS1
					INTEGER,
				kplSlopeS1
					INTEGER,
				kplGainS2
					INTEGER,
				kplSlopeS2
					INTEGER,
				kplGainS3
					INTEGER,
				kplSlopeS3
					INTEGER,
				kplGainS4
					INTEGER,
				kplSlopeS4
					INTEGER,
				kplDet2Offset
					INTEGER,
				kplDet2RefMode
					INTEGER,
				kplDet2RefValue
					INTEGER,
				kplDet2OffsetHiHi
					INTEGER,
				kplDet2OffsetHi
					INTEGER,
				kplDet2OffsetLo
					INTEGER,
				kplDet2OffsetLoLo
					INTEGER,
				kplDet2OffsetDeadband
					INTEGER,
				kplRfLevel2Status
					INTEGER,
				kplDet3Offset
					INTEGER,
				kplDet3RefMode
					INTEGER,
				kplDet3RefValue
					INTEGER,
				kplDet3OffsetHiHi
					INTEGER,
				kplDet3OffsetHi
					INTEGER,
				kplDet3OffsetLo
					INTEGER,
				kplDet3OffsetLoLo
					INTEGER,
				kplDet3OffsetDeadband
					INTEGER,
				kplRfLevel3Status
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.4.31.1.1
		kplGain OBJECT-TYPE
			SYNTAX INTEGER (-2000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value (main input). HF5 input in BKK421.
				Unit 0.01 dB. Control range is -20...0 dB (value range -2000...0)."
			::= { kplEntry 1 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.2
		kplSlope OBJECT-TYPE
			SYNTAX INTEGER (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value (main input). HF5 input in BKK421.
				Unit 0.01 dB. Control range is 0....+ 8 dB ( value range 0...800).
				"
			::= { kplEntry 2 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.3
		kplDetOffset OBJECT-TYPE
			SYNTAX INTEGER (-10000..10000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF detector offset value. Unit 0.01 dB."
			::= { kplEntry 3 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.4
		kplDetRefMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				refFactory(1),
				refUser(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector reference mode.
				1 = factory
				2 = user"
			::= { kplEntry 4 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.5
		kplDetRefValue OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Nominal RF detector value. Unit 0.01 dBµV."
			::= { kplEntry 5 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.6
		kplDetOffsetHiHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector HIGH ALARM limit. Unit 0.01 dB."
			::= { kplEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.7
		kplDetOffsetHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector HIGH WARNING limit. Unit 0.01 dB."
			::= { kplEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.8
		kplDetOffsetLo OBJECT-TYPE
			SYNTAX INTEGER (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector LOW WARNING limit. Unit 0.01 dB."
			::= { kplEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.9
		kplDetOffsetLoLo OBJECT-TYPE
			SYNTAX INTEGER (-10000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector LOW ALARM limit. Unit 0.01 dB."
			::= { kplEntry 9 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.10
		kplDetOffsetDeadband OBJECT-TYPE
			SYNTAX INTEGER (50..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector deadband value. Unit 0.01 dB."
			::= { kplEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.11
		kplDetAverageMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeOff(1),
				modeOn(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF detector averaging status:
				1 = averaging off
				2 = averaging on"
			::= { kplEntry 11 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.13
		kplRfLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"RF detector level status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { kplEntry 13 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.14
		kplTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module temperature Status.
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { kplEntry 14 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.20
		kplGainS1 OBJECT-TYPE
			SYNTAX INTEGER (-2000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value of secondary input 1. HF7-1 input in BKK421.
				Unit 0.01 dB. Control range is -20...0 dB (value range -2000...0).."
			::= { kplEntry 20 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.21
		kplSlopeS1 OBJECT-TYPE
			SYNTAX INTEGER (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value of secondary input 1. HF7-1 input in BKK421.
				Unit 0.01 dB. Control range is 0....+ 8 dB ( value range 0...800)."
			::= { kplEntry 21 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.22
		kplGainS2 OBJECT-TYPE
			SYNTAX INTEGER (-2000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value of secondary input 2. HF7-2 input in BKK421.
