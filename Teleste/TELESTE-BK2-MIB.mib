			::= { kplEntry 24 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.25
		kplSlopeS3 OBJECT-TYPE
			SYNTAX INTEGER (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value of secondary input 3. HF7-3 input in BKK421.
				Unit 0.01 dB. Control range is 0....+ 8 dB ( value range 0...800)."
			::= { kplEntry 25 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.26
		kplGainS4 OBJECT-TYPE
			SYNTAX INTEGER (-2000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value of secondary input 4. HF8 input in BKK421.
				Unit 0.01 dB. Control range is -20...0 dB (value range -2000...0)."
			::= { kplEntry 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.27
		kplSlopeS4 OBJECT-TYPE
			SYNTAX INTEGER (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value of secondary input 4. HF8 input in BKK421.
				Unit 0.01 dB. Control range is 0....+ 8 dB ( value range 0...800)."
			::= { kplEntry 27 }

		
