				apcOFF(1),
				apcON(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"APC (automatic power control) mode:
				1 = APC OFF
				2 = APC ON
				Automatic power control keeps the laser drive RF
				power constant."
			::= { oTxDEntry 67 }

		
