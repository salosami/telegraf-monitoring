				outputOff(2) = optical power OFF"
			::= { oVAEntry 21 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.22
		oVAPumpLaserCurrentRelHi OBJECT-TYPE
			SYNTAX INTEGER (0..15000)
