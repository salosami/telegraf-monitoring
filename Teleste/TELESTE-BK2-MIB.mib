		-- 1.3.6.1.4.1.3715.3.4.25.1.27
		oVASystemStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				systemOk(1),
				systemValueAtLimit(2),
				systemSwitchedOff(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"1 = System OK
				2 = Internal value at its limit
				3 = Output monitor diode defective, device switched off"
			::= { oVAEntry 27 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.28
		oVAPumpLaserStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				laserOk(1),
				laserDefect(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Pump laser 1 status:
				1 = Laser OK
				2 = Laser defect"
			::= { oVAEntry 28 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.29
		oVAPumpLaser2Status OBJECT-TYPE
			SYNTAX INTEGER
				{
				laserOk(1),
				laserDefect(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Pump laser 2 status:
				1 = Laser OK
				2 = Laser defect"
			::= { oVAEntry 29 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.30
		oVAInputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input power status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVAEntry 30 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.31
		oVAOutputParamStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				statusNormal(1),
				statusHIHI(2),
				statusHi(3),
				statusLo(4),
				statusLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain value status, depends 
				on the amplifier operating mode (constant power vs. gain).
				Status values:
				statusNormal(1) = parameter value is within limits
				statusHIHI(2) = parameter value is above the HIHI limit
				statusHi(3) = parameter value is above the Hi limit
				statusLo(4) = parameter value is below the Lo limit
				statusLOLO(5) = parameter value is below the LOLO limit"
			::= { oVAEntry 31 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.32
		oVAPumpLaserCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				biasNormal(1),
				biasHIHI(2),
				biasHI(3),
				biasLO(4),
				biasLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser BIAS current status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVAEntry 32 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.33
		oVAPumpLaserTecCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tecNormal(1),
				tecHIHI(2),
				tecHI(3),
				tecLO(4),
				tecLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"TEC status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVAEntry 33 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.34
		oVARegulationMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modePower(1),
				modeGain(2)
				}
			ACCESS read-write
			STATUS mandatory
			::= { oVAEntry 34 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.35
		oVAInputPowerHiHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power HIGH alarm limit. Unit 0.01 dBm."
			::= { oVAEntry 35 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.36
		oVAOutputParamHiHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain HIGH alarm
				limit. Unit 0.01 dBm."
			::= { oVAEntry 36 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.37
		oVAOutputParamLabel OBJECT-TYPE
			SYNTAX INTEGER
				{
				power(1),
				gain(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Label for all OutputParam objects. Values:
				power(1) = label is 'power' (amplifier is in constant output power mode)
				gain(2) = label is 'gain' (amplifier is in constant gain mode)"
			::= { oVAEntry 37 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.38
		oVAOutputParamUnit OBJECT-TYPE
			SYNTAX INTEGER
				{
				dBm(1),
				dB(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Unit for all OuputParam objects. Values:
				dBm(1) = unit is dBm (amplifier is in constant output power mode)
				dB(2) = unit is dB (amplifier is in constant gain mode)"
			::= { oVAEntry 38 }

		
		-- 1.3.6.1.4.1.3715.3.4.26
		oVTxTable OBJECT-TYPE
			SYNTAX SEQUENCE OF OVTxEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"This table contains element specific information
				for Fibre Transmitter (BOT86X)modules inserted into
				the BK backplane."
			::= { bkModules2 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1
		oVTxEntry OBJECT-TYPE
			SYNTAX OVTxEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"Row in Table. Note that index is moduleIndex which is column in 
				the moduleTable defined in TELESTE-COMMON-MIB. Rows in this table
				exist only if there are corresponding rows in the moduleTable."
			INDEX { moduleId }
			::= { oVTxTable 1 }

		
		OVTxEntry ::=
			SEQUENCE { 
				oVTxOutputPower
					INTEGER,
				oVTxOutputPowerHi
					INTEGER,
				oVTxOutputPowerLo
					INTEGER,
				oVTxOutputPowerLoLo
					INTEGER,
				oVTxOutputPowerDeadband
					INTEGER,
				oVTxRfInputLevel
					INTEGER,
				oVTxRfInputLevelHi
					INTEGER,
				oVTxRfInputLevelLo
					INTEGER,
				oVTxRfInputLevelLoLo
					INTEGER,
				oVTxRfInputLevelDeadband
					INTEGER,
				oVTxRfAttenuation
					INTEGER,
				oVTxOmi
					INTEGER,
				oVTxAgcMode
					INTEGER,
				oVTxLaserCurrentRel
					INTEGER,
				oVTxLaserCurrentRelHi
					INTEGER,
				oVTxLaserCurrentRelDeadband
					INTEGER,
				oVTxTecCurrentRel
					INTEGER,
				oVTxTecCurrentRelHiHi
					INTEGER,
				oVTxTecCurrentRelHi
					INTEGER,
				oVTxTecCurrentRelDeadband
					INTEGER,
				oVTxLaserTemperature
					INTEGER,
				oVTxSbsSuppression
					INTEGER,
				oVTxChannelSpacing
					INTEGER,
				oVTxOutputControl
					INTEGER,
				oVTxRfLevelStatus
					INTEGER,
				oVTxLaserStatus
					INTEGER,
				oVTxTecStatus
					INTEGER,
				oVTxPsuStatus
					INTEGER,
				oVTxFanStatus
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.4.26.1.1
		oVTxOutputPower OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical output power. Unit 0.01 dBm."
			::= { oVTxEntry 1 }

		
