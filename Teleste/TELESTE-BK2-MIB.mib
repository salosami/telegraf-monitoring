		-- 1.3.6.1.4.1.3715.3.4.26.1.13
		oVTxAgcMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				agcOff(1),
				agcCw(2),
				agcVideo(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"1 = AGC off (manual gain control)
				2 = AGC on, calibrated for unmodulated carries
				3 = AGC on, calibrated for modulated carriers"
			::= { oVTxEntry 13 }

		
