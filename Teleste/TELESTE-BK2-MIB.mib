			SYNTAX INTEGER
				{
				rxNormal(1),
				rxSleeping(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 status:
				1 = Normal
				2 = Sleeping"
			::= { oRRxEntry 29 }

		
