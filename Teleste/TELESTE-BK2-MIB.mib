		oVTx2LaserTemperatureOffsetHi OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Laser temperature offset HIGH warning limit. Unit 0.01 degC."
