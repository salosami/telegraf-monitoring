		-- 1.3.6.1.4.1.3715.3.4.30.1.52
		oVTx2OmiHiHi OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Relative OMI HIGH alarm limit. Unit 0.01 dB."
			::= { oVTx2Entry 52 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.53
		oVTx2OmiHi OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Relative OMI HIGH warning limit. Unit 0.01 dB."
			::= { oVTx2Entry 53 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.54
		oVTx2OmiLo OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
