				value. Unit 0.01 dBm."
			::= { oVAEntry 10 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.11
		oVAOutputParamOffset OBJECT-TYPE
			SYNTAX INTEGER (100..5000)
			ACCESS read-write
			STATUS mandatory
