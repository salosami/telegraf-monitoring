		-- 1.3.6.1.4.1.3715.3.4.30.1.57
		oVTx2RfGainHiHi OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"RF gain HIGH alarm limit. Unit 0.01 dB."
