			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain value, depends 
				on the amplifier operating mode (constant power vs. gain).
				Unit 0.01 dBm (power) or 0.01 dB (gain)."
			::= { oVAEntry 6 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.7
		oVAOutputParamHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain HIGH warning ´
				limit. Unit 0.01 dBm."
			::= { oVAEntry 7 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.8
		oVAOutputParamLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain LOW warning 
				limit. Unit 0.01 dBm."
			::= { oVAEntry 8 }

		
		-- 1.3.6.1.4.1.3715.3.4.25.1.9
		oVAOutputParamLoLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
