		-- 1.3.6.1.4.1.3715.3.4.26.1.22
		oVTxSbsSuppression OBJECT-TYPE
			SYNTAX INTEGER (13 | 14 | 15 | 16)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The SBS suppression
				Possible values are: 13, 14, 15, 16 dBm"
			::= { oVTxEntry 22 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.23
		oVTxChannelSpacing OBJECT-TYPE
			SYNTAX INTEGER (1..20)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The channel spacing. Unit 1 MHz."
			::= { oVTxEntry 23 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.24
		oVTxOutputControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				outputOn(1),
				outputOff(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical output control:
				outputOn(1) = optical power ON
				outputOff(2) = optical power OFF"
			::= { oVTxEntry 24 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.25
		oVTxRfLevelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input RF level status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTxEntry 25 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.26
		oVTxLaserStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				laserNormal(1),
				laserHIHI(2),
				laserHI(3),
				laserLO(4),
				laserLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Pump laser status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTxEntry 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.27
		oVTxTecStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tecNormal(1),
				tecHIHI(2),
				tecHI(3),
				tecLO(4),
				tecLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"TEC status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTxEntry 27 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.28
		oVTxPsuStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				psuNormal(1),
				psuFailure(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Power supply status:
				1 = Both power supplies are OK
				2 = One of two power supplies fails"
			::= { oVTxEntry 28 }

		
		-- 1.3.6.1.4.1.3715.3.4.26.1.29
		oVTxFanStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				fanNormal(1),
				fanOneFail(2),
				fanTwoFail(3)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Fan status:
				1 = Fans OK
				2 = One fan fails
				3 = Two fans fail
				"
			::= { oVTxEntry 29 }

		
