		-- 1.3.6.1.4.1.3715.3.4.27.1.66
		oTxDConfig OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Transmitter configuration information.
				Bit based encoding:
				bit 0: 1 = Cooled laser
				bit 1: 1 = LON module used
				bit 2: 1 = Wavelength monitor supported
				bit 3: 1 = ITU frequency not adjustable
				bit 4: 1 = ITU frequency not valid"
			::= { oTxDEntry 66 }

		
		-- 1.3.6.1.4.1.3715.3.4.27.1.67
		oTxDApcMode OBJECT-TYPE
			SYNTAX INTEGER
