		-- 1.3.6.1.4.1.3715.3.4.25.1.10
		oVAOutputParamDeadband OBJECT-TYPE
			SYNTAX INTEGER (50..500)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
