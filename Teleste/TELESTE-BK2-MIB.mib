		oRRx1InputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 input power status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oRRxEntry 30 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.31
		oRRx1PilotStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				pilotNormal(1),
				pilotFailure(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 pilot status:
				1 = normal
				2 = pilot failure"
			::= { oRRxEntry 31 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.32
		oRRx1CodeStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				codeNormal(1),
				codeMismatch(2),
				codeInvalid(3),
				codeDisabled(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 1 code status:
				codeNormal(1)   = normal
				codeMismatch(2) = code mismatch (expected code not equal to received)
				codeInvalid(3)  = invalid code received (0)
				codeDisabled(4) = code reception is disabled"
			::= { oRRxEntry 32 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.33
		oRRx2Status OBJECT-TYPE
			SYNTAX INTEGER
				{
				rxNormal(1),
				rxSleeping(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 status:
				1 = Active
				2 = Sleeping"
			::= { oRRxEntry 33 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.34
		oRRx2InputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 input power status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oRRxEntry 34 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.35
		oRRx2PilotStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				pilotNormal(1),
				pilotFailure(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 pilot status:
				1 = normal
				2 = pilot failure"
			::= { oRRxEntry 35 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.36
		oRRx2CodeStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				codeNormal(1),
				codeMismatch(2),
				codeInvalid(3),
				codeDisabled(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Receiver 2 code status:
				codeNormal(1)   = normal
				codeMismatch(2) = code mismatch (expected code not equal to received)
				codeInvalid(3)  = invalid code received (0)
				codeDisabled(4) = code reception is disabled
				"
			::= { oRRxEntry 36 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.37
		oRRxCmnLinkStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				linkNormal(1),
				linkReserve(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Link status:
				1 = normal
				2 = reserve"
			::= { oRRxEntry 37 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.38
		oRRxCmnIngressSwitchStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				switchNominal(1),
				switchNotNominal(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Common ingress switch status:
				switchNominal(1)=Both switches are in nominal positions
				switchNotNominal(2)= One or both swicthes are not in nominal position"
			::= { oRRxEntry 38 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.39
		oRRxCmnNominalPortControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				returnToNominal(1),
				defineAsNominal(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"This object controls the return path switches 'nominal'
				setting. Any combination of the switch positions can be
				defined as the 'nominal' setting. A reminder alarm
				will be initiated if any of the switches is not in it's
				nominal position.
				
				Set operations:
				1 = returnToNominal, returns all switches to their nominal
				    positions
				2 = defineNominal, stores the current port configuration
				    as the nominal configuration. 
				
				Get operations
				1 = all switches are in their nominal positions
				2 = one or more switches is not in it's nominal position
				
				Note: Immediately after a set (1 or 2), the return value 
				will be 1 meaning that the switches are in their nominal
				positions.
				
				With BKR100 this object is read only. Returned value is
				always 1 (returnToNominal)."
			::= { oRRxEntry 39 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.40
		oRRxCmnNotchControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				notchDisable(1),
				notchEnable(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Control of the 65 MHz notch:
				1(notchDisable) = notch OFF
				2(notchEnable) = notch ON"
			::= { oRRxEntry 40 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.41
		oRRx1Gain OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Input 1 gain control value. Unit 0.01 dB."
			::= { oRRxEntry 41 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.42
		oRRx1AlcMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeManual(1),
				modeAlc(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Input 1 ALC mode:
				modeManual(1)=manual gain control
				modeAlc(2)   =automatic gain control"
			::= { oRRxEntry 42 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.43
		oRRx1AlcStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				alcNormal(1),
				alcSaturated(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input 1 ALC status:
				alcNormal(1)    =ALC operates normally
				alcSaturated(2) =ALC is saturated
				If oRRx1AlcMode is set to modeManual(1), this object always
				returns value alsNormal(1)."
			::= { oRRxEntry 43 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.44
		oRRx2Gain OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Input 2 gain control value. Unit 0.01 dB."
			::= { oRRxEntry 44 }

		
		-- 1.3.6.1.4.1.3715.3.4.28.1.47
		oRRxCmnSlope OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value. Unit 0.01 dB. Common to both inputs."
			::= { oRRxEntry 47 }

		
		-- 1.3.6.1.4.1.3715.3.4.29
		oVA2Table OBJECT-TYPE
			SYNTAX SEQUENCE OF OVA2Entry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"This table contains element specific information
				for Optical Amplifier modules inserted into
				the BK backplane."
			::= { bkModules2 29 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1
		oVA2Entry OBJECT-TYPE
			SYNTAX OVA2Entry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"Row in Table. Note that index is moduleIndex which is column in 
				the moduleTable defined in TELESTE-COMMON-MIB. Rows in this table
				exist only if there are corresponding rows in the moduleTable."
			INDEX { moduleId }
			::= { oVA2Table 1 }

		
		OVA2Entry ::=
			SEQUENCE { 
				oVa2InputPower
					INTEGER,
				oVa2InputPowerHiHi
					INTEGER,
				oVa2InputPowerHi
					INTEGER,
				oVa2InputPowerLo
					INTEGER,
				oVa2InputPowerLoLo
					INTEGER,
				oVa2InputPowerDeadband
					INTEGER,
				oVa2OutputParamOffset
					INTEGER,
				oVa2OutputParamOffsetHiHi
					INTEGER,
				oVa2OutputParamOffsetHi
					INTEGER,
				oVa2OutputParamOffsetLo
					INTEGER,
				oVa2OutputParamOffsetLoLo
					INTEGER,
				oVa2OutputParamOffsetDeadband
					INTEGER,
				oVa2OutputParamNominal
					INTEGER,
				oVa2OutputParamStepSize
					INTEGER,
				oVa2OutputParamControl
					INTEGER,
				oVa2OutputParamControlMax
					INTEGER,
				oVa2OutputParamControlMin
					INTEGER,
				oVa2OutputControl
					INTEGER,
				oVa2RegulationMode
					INTEGER,
				oVa2SystemInfo
					INTEGER,
				oVa2ReturnLoss
					INTEGER,
				oVa2ReturnLossHiHi
					INTEGER,
				oVa2ReturnLossHi
					INTEGER,
				oVa2ReturnLossLo
					INTEGER,
				oVa2ReturnLossLoLo
					INTEGER,
				oVa2ReturnLossDeadband
					INTEGER,
				oVa2SbsEvaluationMode
					INTEGER,
				oVa2SbsEvaluationStart
					INTEGER,
				oVa2SbsEvaluationTime
					INTEGER,
				oVa2SbsPowerValue
					INTEGER,
				oVa2SystemStatus
					INTEGER,
				oVa2InputPowerStatus
					INTEGER,
				oVa2OutputParamStatus
					INTEGER,
				oVa2ReturnLossStatus
					INTEGER,
				oVa2InputVoltageStatus
					INTEGER,
				oVa2InternalVoltageStatus
					INTEGER,
				oVa2InternalTemperatureStatus
					INTEGER,
				oVa2NumberOfLasers
					INTEGER,
				oVa2StandbyStatus
					INTEGER,
				oVa2LaserCurrentRelStatus
					INTEGER,
				oVa2LaserTecCurrentRelStatus
					INTEGER,
				oVa2LaserTemperatureStatus
					INTEGER,
				oVa2LaserVoltageStatus
					INTEGER,
				oVA2OutputParamLabel
					INTEGER,
				oVA2OutputParamUnit
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.4.29.1.1
		oVa2InputPower OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical input power. Unit 0.01 dBm."
			::= { oVA2Entry 1 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.2
		oVa2InputPowerHiHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power HIGH alarm limit. Unit 0.01 dBm."
			::= { oVA2Entry 2 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.3
		oVa2InputPowerHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power HIGH warning limit. Unit 0.01 dBm."
			::= { oVA2Entry 3 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.4
		oVa2InputPowerLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power LOW warning limit. Unit 0.01 dBm."
			::= { oVA2Entry 4 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.5
		oVa2InputPowerLoLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..1000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power LOW alarm limit. Unit 0.01 dBm."
			::= { oVA2Entry 5 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.6
		oVa2InputPowerDeadband OBJECT-TYPE
			SYNTAX INTEGER (50..500)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical input power deadband value. Unit 0.01 dBm."
			::= { oVA2Entry 6 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.7
		oVa2OutputParamOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset (from target value). Unit 0.01 dBm
				In constant gain mode: Gain offset (from target value). Unit 0.01 dB"
			::= { oVA2Entry 7 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.8
		oVa2OutputParamOffsetHiHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset HIHI limit value. Unit 0.01 dBm
				In constant gain mode: Gain offset HIHI limit value. Unit 0.01 dB"
			::= { oVA2Entry 8 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.9
		oVa2OutputParamOffsetHi OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset Hi limit value. Unit 0.01 dBm
				In constant gain mode: Gain offset Hi limit value. Unit 0.01 dB"
			::= { oVA2Entry 9 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.10
		oVa2OutputParamOffsetLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset Lo limit value. Unit 0.01 dBm
				In constant gain mode: Gain offset Lo limit value. Unit 0.01 dB"
			::= { oVA2Entry 10 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.11
		oVa2OutputParamOffsetLoLo OBJECT-TYPE
			SYNTAX INTEGER (-1000..3000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset LOLO limit value. Unit 0.01 dBm
				In constant gain mode: Gain offset LOLO limit value. Unit 0.01 dB"
			::= { oVA2Entry 11 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.12
		oVa2OutputParamOffsetDeadband OBJECT-TYPE
			SYNTAX INTEGER (50..500)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power offset deadband value. Unit 0.01 dBm
				In constant gain mode: Gain offset deadband value. Unit 0.01 dB"
			::= { oVA2Entry 12 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.13
		oVa2OutputParamNominal OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power nominal value. Unit 0.01 dBm
				In constant gain mode: Gain nominal value. Unit 0.01 dB"
			::= { oVA2Entry 13 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.14
		oVa2OutputParamStepSize OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power control step size. Unit 0.01 dBm
				In constant gain mode: Gain control step size. Unit 0.01 dB"
			::= { oVA2Entry 14 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.15
		oVa2OutputParamControl OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power control value (difference from nominal value). Unit 0.01 dBm
				In constant gain mode: Gain control value (difference from nominal value). Unit 0.01 dB"
			::= { oVA2Entry 15 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.16
		oVa2OutputParamControlMax OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power control maximum value. Unit 0.01 dBm
				In constant gain mode: Gain control maximum value. Unit 0.01 dB"
			::= { oVA2Entry 16 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.17
		oVa2OutputParamControlMin OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"In constant output power mode: Optical output power control minimum value. Unit 0.01 dBm
				In constant gain mode: Gain control minimum value. Unit 0.01 dB"
			::= { oVA2Entry 17 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.18
		oVa2OutputControl OBJECT-TYPE
			SYNTAX INTEGER
				{
				outputOn(1),
				outputOff(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical output control:
				outputOn(1) = optical power ON
				outputOff(2) = optical power OFF"
			::= { oVA2Entry 18 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.19
		oVa2RegulationMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modePower(1),
				modeGain(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Amplifier operating mode:
				modePower(1) = constant output power mode
				modeGain(2) = constant gain mode
				This setting affects the meaning, value and unit meaning of multiple objects
				as described in the deciptions of the respective objects
				"
			::= { oVA2Entry 19 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.20
		oVa2SystemInfo OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Additional system info, bitwise encoded.
				Bit 0: SBS features supported 
				Bit 1: External I/Os supported 
				Bit 2: PowerSupply and Fans supported 
				Bit 3: ReturnLoss detection supported 
				Bit 4: Edfa is a HighPower type 
				Bit 5: reserved"
			::= { oVA2Entry 20 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.21
		oVa2ReturnLoss OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured return loss value. Unit 0.01 dB."
			::= { oVA2Entry 21 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.22
		oVa2ReturnLossHiHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return loss HIGH alarm limit. Unit 0.01 dB."
			::= { oVA2Entry 22 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.23
		oVa2ReturnLossHi OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return loss HIGH warning limit. Unit 0.01 dB."
			::= { oVA2Entry 23 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.24
		oVa2ReturnLossLo OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return loss LOW warning limit. Unit 0.01 dB."
			::= { oVA2Entry 24 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.25
		oVa2ReturnLossLoLo OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return loss LOW alarm limit. Unit 0.01 dB."
			::= { oVA2Entry 25 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.26
		oVa2ReturnLossDeadband OBJECT-TYPE
			SYNTAX INTEGER (0..10000)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Return loss deadband value. Unit 0.01 dB."
			::= { oVA2Entry 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.27
		oVa2SbsEvaluationMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeStandard(1),
				modeFull(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"SBS evaluation mode:
				modeStandard(1) = standard mode
				modeFull(2) = full mode"
			::= { oVA2Entry 27 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.28
		oVa2SbsEvaluationStart OBJECT-TYPE
			SYNTAX INTEGER { evaluationStart(1) }
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Start SBS evaluation. Write only object, value:
				evaluationStart(1) = start SBS evaluation"
			::= { oVA2Entry 28 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.29
		oVa2SbsEvaluationTime OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Time of last SBS evaluation. POSIX format."
			::= { oVA2Entry 29 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.30
		oVa2SbsPowerValue OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured SBS power value. Unit 0.01 dBm."
			::= { oVA2Entry 30 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.31
		oVa2SystemStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				systemOk(1),
				systemAlarm(2),
				systemWarning(3),
				systemNotification(4)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"1 = System OK
				2 = System alarm
				3 = System warning
				4 = System notification"
			::= { oVA2Entry 31 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.32
		oVa2InputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input power status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVA2Entry 32 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.33
		oVa2OutputParamStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				statusNormal(1),
				statusHIHI(2),
				statusHi(3),
				statusLo(4),
				statusLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical output power or amplifier gain value status, depends 
				on the amplifier operating mode (constant power vs. gain).
				Status values:
				statusNormal(1) = parameter value is within limits
				statusHIHI(2) = parameter value is above the HIHI limit
				statusHi(3) = parameter value is above the Hi limit
				statusLo(4) = parameter value is below the Lo limit
				statusLOLO(5) = parameter value is below the LOLO limit"
			::= { oVA2Entry 33 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.34
		oVa2ReturnLossStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				returnLossNormal(1),
				returnLossHIHI(2),
				returnLossHI(3),
				returnLossLO(4),
				returnLossLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Return loss status
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVA2Entry 34 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.35
		oVa2InputVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module input voltage  status
				normal(1) = voltage is within limits
				alarm(2) = voltage is outside limits"
			::= { oVA2Entry 35 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.36
		oVa2InternalVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module internal voltage  status
				normal(1) = voltages are within limits
				alarm(2) = one or more voltages are outside limits"
			::= { oVA2Entry 36 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.37
		oVa2InternalTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Module internal temperature status
				normal(1) = temperature is within limits
				alarm(2) = temperature is outside limits"
			::= { oVA2Entry 37 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.38
		oVa2NumberOfLasers OBJECT-TYPE
			SYNTAX INTEGER (1..4)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of pump lasers."
			::= { oVA2Entry 38 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.39
		oVa2StandbyStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				noStandby(1),
				standby(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Standby status, values:
				noStandby(1)= active (optical output is on)
				standby(2) = standby (optical output off)"
			::= { oVA2Entry 39 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.40
		oVa2LaserCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser BIAS current status
				normal(1) = bias current is within limits
				alarm(2) = bias current is outside limits"
			::= { oVA2Entry 40 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.41
		oVa2LaserTecCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser TEC current status (TEC = thermo electric cooler)
				normal(1) = TEC current is within limits
				alarm(2) = TEC current is outside limits"
			::= { oVA2Entry 41 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.42
		oVa2LaserTemperatureStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser temperature status
				normal(1) = temperature is within limits
				alarm(2) = temperature is outside limits"
			::= { oVA2Entry 42 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.43
		oVa2LaserVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				normal(1),
				alarm(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser voltage status
				normal(1) = voltage is within limits
				alarm(2) = voltage is outside limits"
			::= { oVA2Entry 43 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.44
		oVA2OutputParamLabel OBJECT-TYPE
			SYNTAX INTEGER
				{
				power(1),
				gain(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Label for all OutputParam objects. Values:
				power(1) = label is 'power' (amplifier is in constant output power mode)
				gain(2) = label is 'gain' (amplifier is in constant gain mode)"
			::= { oVA2Entry 44 }

		
		-- 1.3.6.1.4.1.3715.3.4.29.1.45
		oVA2OutputParamUnit OBJECT-TYPE
			SYNTAX INTEGER
				{
				dBm(1),
				dB(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Unit for all OuputParam objects. Values:
				dBm(1) = unit is dBm (amplifier is in constant output power mode)
				dB(2) = unit is dB (amplifier is in constant gain mode)"
			::= { oVA2Entry 45 }

		
		-- 1.3.6.1.4.1.3715.3.4.30
		oVTx2Table OBJECT-TYPE
			SYNTAX SEQUENCE OF OVTx2Entry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"This table contains element specific information
				for Fibre Transmitter (BOT86X)modules inserted into
				the BK backplane."
			::= { bkModules2 30 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1
		oVTx2Entry OBJECT-TYPE
			SYNTAX OVTx2Entry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"Row in Table. Note that index is moduleIndex which is column in 
				the moduleTable defined in TELESTE-COMMON-MIB. Rows in this table
				exist only if there are corresponding rows in the moduleTable."
			INDEX { moduleId }
			::= { oVTx2Table 1 }

		
		OVTx2Entry ::=
			SEQUENCE { 
				oVTx2OutputPower
					INTEGER,
				oVTx2OutputPowerStatus
					INTEGER,
				oVTx2RfInputPower
					INTEGER,
				oVTx2RfInputPowerStatus
					INTEGER,
				oVTx2Omi
					INTEGER,
				oVTx2OmiStatus
					INTEGER,
				oVTx2RfGain
					INTEGER,
				oVTx2RfGainStatus
					INTEGER,
				oVTx2LaserCurrentRel
					INTEGER,
				oVTx2LaserCurrentRelStatus
					INTEGER,
				oVTx2TecCurrentRel
					INTEGER,
				oVTx2TecCurrentRelStatus
					INTEGER,
				oVTx2LaserTemperatureOffset
					INTEGER,
				oVTx2LaserTemperatureOffsetStatus
					INTEGER,
				oVTx2PowerSupplyStatus
					INTEGER,
				oVTx2InternalVoltageStatus
					INTEGER,
				oVTx2RfInputSignalStatus
					INTEGER,
				oVTx2FanStatus
					INTEGER,
				oVTx2StandbyStatus
					INTEGER,
				oVTx2AgcStatus
					INTEGER,
				oVTx2SbsStatus
					INTEGER,
				oVTx2InternalAlarm
					INTEGER,
				oVTx2RegulationState
					INTEGER,
				oVTx2DeviceModeA
					INTEGER,
				oVTx2DeviceModeB
					INTEGER,
				oVTx2OmiNominal
					INTEGER,
				oVTx2LaserTemperatureNominal
					INTEGER,
				oVTx2LaserFrequencyNominal
					INTEGER,
				oVTx2LaserOperationMode
					INTEGER,
				oVTx2AgcMode
					INTEGER,
				oVTx2CsoRegulation
					INTEGER,
				oVTx2ChannelDistance
					INTEGER,
				oVTx2FiberLength
					INTEGER,
				oVTx2OmiOffset
					INTEGER,
				oVTx2RfGainOffset
					INTEGER,
				oVTx2SlopeOffset
					INTEGER,
				oVTx2LaserFrequencyOffset
					INTEGER,
				oVTx2SbsSuppression
					INTEGER,
				oVTx2SbsSupressionMode
					INTEGER,
				oVTx2SbsFiberType
					INTEGER,
				oVTx2SbsFiberLength
					INTEGER,
				oVTx2OutputPowerRelHiHi
					INTEGER,
				oVTx2OutputPowerRelHi
					INTEGER,
				oVTx2OutputPowerRelLo
					INTEGER,
				oVTx2OutputPowerRelLoLo
					INTEGER,
				oVTx2OutputPowerRelDeadband
					INTEGER,
				oVTx2RfInputPowerHiHi
					INTEGER,
				oVTx2RfInputPowerHi
					INTEGER,
				oVTx2RfInputPowerLo
					INTEGER,
				oVTx2RfInputPowerLoLo
					INTEGER,
				oVTx2RfInputPowerDeadband
					INTEGER,
				oVTx2OmiHiHi
					INTEGER,
				oVTx2OmiHi
					INTEGER,
				oVTx2OmiLo
					INTEGER,
				oVTx2OmiLoLo
					INTEGER,
				oVTx2OmiDeadband
					INTEGER,
				oVTx2RfGainHiHi
					INTEGER,
				oVTx2RfGainHi
					INTEGER,
				oVTx2RfGainLo
					INTEGER,
				oVTx2RfGainLoLo
					INTEGER,
				oVTx2RfGainDeadband
					INTEGER,
				oVTx2LaserCurrentRelHi
					INTEGER,
				oVTx2LaserCurrentRelDeadband
					INTEGER,
				oVTx2TecCurrentRelHiHi
					INTEGER,
				oVTx2TecCurrentRelHi
					INTEGER,
				oVTx2TecCurrentRelDeadband
					INTEGER,
				oVTx2LaserTemperatureOffsetHi
					INTEGER,
				oVTx2LaserTemperatureOffsetLo
					INTEGER,
				oVTx2LaserTemperatureOffsetDeadband
					INTEGER
			 }

		-- 1.3.6.1.4.1.3715.3.4.30.1.1
		oVTx2OutputPower OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured optical output power value. Unit 0.01 dBm."
			::= { oVTx2Entry 1 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.2
		oVTx2OutputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				powerNormal(1),
				powerHIHI(2),
				powerHI(3),
				powerLO(4),
				powerLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Optical output power status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 2 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.3
		oVTx2RfInputPower OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Total RF input power level. Unit 0.01 dBm."
			::= { oVTx2Entry 3 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.4
		oVTx2RfInputPowerStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				levelNormal(1),
				levelHIHI(2),
				levelHI(3),
				levelLO(4),
				levelLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input RF Power status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 4 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.5
		oVTx2Omi OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Measured relative OMI. Unit 0.01 dB."
			::= { oVTx2Entry 5 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.6
		oVTx2OmiStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				omiNormal(1),
				omiHIHI(2),
				omiHI(3),
				omiLO(4),
				omiLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Relative OMI status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 6 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.7
		oVTx2RfGain OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"BC input RF gain control value in APC mode. Unit 0.01 dB."
			::= { oVTx2Entry 7 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.8
		oVTx2RfGainStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				gainNormal(1),
				gainHIHI(2),
				gainHI(3),
				gainLO(4),
				gainLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Input RF gain status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 8 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.9
		oVTx2LaserCurrentRel OBJECT-TYPE
			SYNTAX INTEGER (0..15000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser BIAS current value relative to the value at the
				beginning of life (0...150%). Unit 0.01 %."
			::= { oVTx2Entry 9 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.10
		oVTx2LaserCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				currentNormal(1),
				currentHIHI(2),
				currentHI(3),
				currentLO(4),
				currentLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser bias current status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 10 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.11
		oVTx2TecCurrentRel OBJECT-TYPE
			SYNTAX INTEGER (-10000..10000)
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"TEC current relative to a max. value (0...100%).
				Unit 0.01 %.
				Cooling = positive value, heating = negative value."
			::= { oVTx2Entry 11 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.12
		oVTx2TecCurrentRelStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				currentNormal(1),
				currentHIHI(2),
				currentHI(3),
				currentLO(4),
				currentLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"TEC current status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 12 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.13
		oVTx2LaserTemperatureOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser temperature offset from nominal laser temperature.
				Unit 0.01 degC."
			::= { oVTx2Entry 13 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.14
		oVTx2LaserTemperatureOffsetStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				tempNormal(1),
				tempHIHI(2),
				tempHI(3),
				tempLO(4),
				tempLOLO(5)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Laser temperature offset status:
				1 = OK
				2 = HIHI
				3 = HI
				4 = LO
				5 = LOLO"
			::= { oVTx2Entry 14 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.15
		oVTx2PowerSupplyStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				psuOk(1),
				psuAlert(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Power supply status."
			::= { oVTx2Entry 15 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.16
		oVTx2InternalVoltageStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				voltageGood(1),
				voltageBad(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Internal supply voltage status.
				This is a common status object for all internal voltages."
			::= { oVTx2Entry 16 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.17
		oVTx2RfInputSignalStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				signalOk(1),
				signalLost(2)
				}
			ACCESS read-write
			STATUS mandatory
			::= { oVTx2Entry 17 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.18
		oVTx2FanStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				fanOk(1),
				fanAlert(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Fan status."
			::= { oVTx2Entry 18 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.19
		oVTx2StandbyStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				noStandby(1),
				standby(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Standby status, values:
				noStandby(1)= active
				standby(2) = standby"
			::= { oVTx2Entry 19 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.20
		oVTx2AgcStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				agcOk(1),
				agcAlert(2)
				}
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"AGC status."
			::= { oVTx2Entry 20 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.21
		oVTx2SbsStatus OBJECT-TYPE
			SYNTAX INTEGER
				{
				sbsOk(1),
				sbsAlarms(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"sbsAlarms(2) if one or more of following conditions
				- SBS 2 GHz/6 GHz level alarm.
				- PLL 2 GHz/6 GHz PLL alarm.
				otherwise sbsOk(1)."
			::= { oVTx2Entry 21 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.22
		oVTx2InternalAlarm OBJECT-TYPE
			SYNTAX INTEGER
				{
				alarmNo(1),
				alarmYes(2)
				}
			ACCESS read-write
			STATUS mandatory
			::= { oVTx2Entry 22 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.23
		oVTx2RegulationState OBJECT-TYPE
			SYNTAX INTEGER
				{
				rsPout(1),
				rsCSOrough(2),
				rsCSOfine(3),
				rsPilot(4)
				}
			ACCESS read-only
			STATUS mandatory
			::= { oVTx2Entry 23 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.24
		oVTx2DeviceModeA OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bit0: Extended parameter mode used
				Bit1: No Sbs support
				Bit2: Sbs suppression not changeable
				Bit3: No Itu frequency support 
				Bit4: Itu frequency not changeable
				Bit5  PowerSupply and Fans supported 
				Bit6: External I/Os supported
				Bit7: Fiberlength supported
				Bit8: Catv input not supported
				Bit9: Sat input not supported
				Bit10: SAT LNB supply supported
				Bit11: SAT LNB 22kHz supported
				Bit12: Sbs hardware v2 supported
				Bit13: Pilot controlled cso regulation supported"
			::= { oVTx2Entry 24 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.25
		oVTx2DeviceModeB OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Bit0: Sbs hardware v3 supported
				Bit1: Sbs frequency mode supported
				Bit1: Sbs suppression mode supported
				Bit2: Internal alarm supported
				Bit3: reserved 
				Bit4: Sbs fiber parameters supported
				"
			::= { oVTx2Entry 25 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.26
		oVTx2OmiNominal OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Nominal OMI. Unit 0.01 %."
			::= { oVTx2Entry 26 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.27
		oVTx2LaserTemperatureNominal OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Nominal laser temperature. Unit 0.01 degC."
			::= { oVTx2Entry 27 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.28
		oVTx2LaserFrequencyNominal OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Nominal laser frequency. Unit 10 MHz."
			::= { oVTx2Entry 28 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.29
		oVTx2LaserOperationMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				laserOff(1),
				laserOn(2),
				laserOffIfError(3)
				}
			ACCESS read-write
			STATUS mandatory
			::= { oVTx2Entry 29 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.30
		oVTx2AgcMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				agcManual(1),
				agcAuto(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"1: Manual	AGC off
				2: Auto/CW	AGC on, OMI set for unmodulated carriers
				3: reserved - do not use"
			::= { oVTx2Entry 30 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.31
		oVTx2CsoRegulation OBJECT-TYPE
			SYNTAX INTEGER
				{
				csoByChannel(1),
				csoByPilot(2)
				}
			ACCESS read-write
			STATUS mandatory
			::= { oVTx2Entry 31 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.32
		oVTx2ChannelDistance OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The channel distance, active for oVTx2CsoRegulation 'csoByChannel' (6MHz, 7MHz, 8MHz). Unit 0.01 MHz."
			::= { oVTx2Entry 32 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.33
		oVTx2FiberLength OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Connected fiber length, valid for oVTx2DeviceModeA (Bit7: Fiberlength supported). Unit 0.01 km."
			::= { oVTx2Entry 33 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.34
		oVTx2OmiOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Optical Modulation Index (relative to nominal omi). Unit 0.01dB."
			::= { oVTx2Entry 34 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.35
		oVTx2RfGainOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The RF gain value (relative to nominal gain) Unit 0.01 dB."
			::= { oVTx2Entry 35 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.36
		oVTx2SlopeOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope (relative to nominal slope). Unit 0.01 dB."
			::= { oVTx2Entry 36 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.37
		oVTx2LaserFrequencyOffset OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Laser frequency offset from nominal value. Unit 10 MHz."
			::= { oVTx2Entry 37 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.38
		oVTx2SbsSuppression OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The displayed Sbs suppression. This is not equal to the SBS value set inside the device! Unit 0.01dBm."
			::= { oVTx2Entry 38 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.39
		oVTx2SbsSupressionMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				standard(1),
				catvOnly(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"SBS suppression mode
				0: Standard
				( ES28: CATV & SAT-IF or SAT-IF only )
				 ES10: -1006 MHz )
				1: CATV only
				( ES28: CATV only; ES10: -862 MHz )
				(Available at NEC-E only if Sbs suppression mode supported)
				Note: changing this value results in a change of parameters 73, 74 and 120. Reread is necessary.
				"
			::= { oVTx2Entry 39 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.40
		oVTx2SbsFiberType OBJECT-TYPE
			SYNTAX INTEGER
				{
				singleModeStandard(1),
				singleModeEnhanced(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Fiber Type:
				0: Standard SMF (Single Mode Fiber)
				1: SBS Enhanced SMF (Single Mode Fiber)
				(Available only if Sbs fiber parameters supported)
				Note: changing this value results in a change of parameters 73, 74 and 120. Reread is necessary."
			::= { oVTx2Entry 40 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.41
		oVTx2SbsFiberLength OBJECT-TYPE
			SYNTAX INTEGER
				{
				len10km(1),
				len25km(2),
				len40km(3),
				len65km(4)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"SBS fiber length
				0: 10km
				1: 25km
				2: 40km
				3: 65km
				(Available only if Sbs fiber parameters supported: See oVTx2DeviceModeB)
				Note: changing this value results in a change of parameters 73, 74 and 120. Reread is necessary.
				"
			::= { oVTx2Entry 41 }

		
