		-- 1.3.6.1.4.1.3715.3.4.23.1.13
		oPSMode OBJECT-TYPE
			SYNTAX INTEGER
				{
				modeManual(1),
				modeRevertive(2),
				modeNonRevertive(3)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"1 Manual - The position of the optical switch is, independent of the 
				input signals, switched by the POSITION parameter.
				
				2 Revertive - The position of the optical switch automatically falls back
				from the reserve to the main channel, if the main channels
				signal is good during the fallback waittime.
				
				3 Non Revertive - The position of the optical switch stays in the reserve
				channel until the SWITCH_BACK parameter is written or the
				reserve channels signal fails."
			::= { oPSEntry 13 }

		
