			::= { oVTx2Entry 63 }

		
		-- 1.3.6.1.4.1.3715.3.4.30.1.64
		oVTx2TecCurrentRelHiHi OBJECT-TYPE
			SYNTAX INTEGER (-10000..10000)
			ACCESS read-write
