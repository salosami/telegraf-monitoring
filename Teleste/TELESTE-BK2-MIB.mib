			::= { kplEntry 22 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.23
		kplSlopeS2 OBJECT-TYPE
			SYNTAX INTEGER (0..800)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Slope control value of secondary input 2. HF7-2 input in BKK421.
				Unit 0.01 dB. Control range is 0....+ 8 dB ( value range 0...800)."
			::= { kplEntry 23 }

		
		-- 1.3.6.1.4.1.3715.3.4.31.1.24
		kplGainS3 OBJECT-TYPE
			SYNTAX INTEGER (-2000..0)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Gain control value of secondary input 3. HF7-3 input in BKK421.
