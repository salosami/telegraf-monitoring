		trapControl OBJECT IDENTIFIER ::= { functional 101 }

		
		-- 1.3.6.1.4.1.3715.100.101.1
		trapSending OBJECT-TYPE
			SYNTAX INTEGER
				{
				enabled(1),
				disabled(2)
				}
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Trap sending master switch.
				Enables/disables trap sending:
				enabled(1) = traps are sent to enabled IP addresses in trapReceiverTable
				disabled(2) = all trap sending is disabled"
			::= { trapControl 1 }

		
		-- 1.3.6.1.4.1.3715.100.101.2
		trapDelay OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The first trap placed into empty trap queue should be sent 
				after the initial delay specified in this object.
				
				- Unit 1 ms
				- Minimum value 0 (0 ms)
				- Maximum value 60000 (60 seconds)
				- Default value 1000 (1 seconds)
				
				The purpose of this parameter is to avoid trap storms."
			::= { trapControl 2 }

		
		-- 1.3.6.1.4.1.3715.100.101.3
		trapInterval OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The minimum interval between two succesive traps.
				- Unit 1 milliseconds
				- Minimum value 0 (send as fast as possible)
				- Maximum value 10000 (10 seconds)
				- Default value is 1000 (1 second)"
			::= { trapControl 3 }

		
		-- 1.3.6.1.4.1.3715.100.101.4
		trapLifeTime OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"The maximum time a trap stays in the trap queue waiting
				for sending.
				- Unit 1 second.
				- Minimum value 10
				- Maximum value 300
				- Default value 60"
			::= { trapControl 4 }

		
		-- 1.3.6.1.4.1.3715.100.101.5
		numberOfTrapReceivers OBJECT-TYPE
			SYNTAX INTEGER
			ACCESS read-only
			STATUS mandatory
			DESCRIPTION
				"Number of entries in the trapReceiverTable. 
				At least one trap receiver entry must be supported."
			::= { trapControl 5 }

		
		-- 1.3.6.1.4.1.3715.100.101.6
		trapReceiverTable OBJECT-TYPE
			SYNTAX SEQUENCE OF TrapReceiverEntry
			ACCESS not-accessible
			STATUS mandatory
			DESCRIPTION
				"A table of trap receiver addresses, ports and
				communities. The number of entries is given by 
				numberOfTrapReceivers. An entry is deleted from this
				table by setting its IP address to '0.0.0.0'.
				"
			::= { trapControl 6 }

		
		-- 1.3.6.1.4.1.3715.100.101.6.1
