		-- 1.3.6.1.4.1.3715.100.101.6.1.3
		receiverPort OBJECT-TYPE
			SYNTAX INTEGER (1..65535)
			ACCESS read-write
			STATUS mandatory
			DESCRIPTION
				"Trap UDP port number. 
				Default port is the standard trap port 162."
