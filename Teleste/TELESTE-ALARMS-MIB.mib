			::= { alarms 5 }

		
	
--
-- Trap definitions
--
	
-- Trap definitions
		alarmEvent TRAP-TYPE 
			ENTERPRISE teleste
			VARIABLES { elementName, eventTime, eventSeverity, eventParameterOID, eventParameterValue, 
